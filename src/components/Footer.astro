</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    margin-top: 5rem;
    padding: 3rem 0 2rem;
  }
  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .footer-col {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .brand-mini {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
  }
  .mini-mark {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--grad);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
  }
  .dim { color: var(--ink-faint); }
  .footer-links a {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    border-bottom: none;
    transition: color 0.15s ease;
  }
  .footer-links a:hover { color: var(--ink); }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .social-link svg {
    transition: color 0.15s ease, transform 0.15s ease;
    color: var(--ink-faint);
  }
  .social-link:hover svg { transform: translateY(-1px); }
  .social-link.github:hover svg { color: #181717; }
  .social-link.linkedin:hover svg { color: #0a66c2; }
  .social-link.email:hover svg { color: #ea4335; }
  .social-link.rss:hover svg { color: #f26522; }
  .footer-meta {
    padding-top: 1.25rem;
  }
</style>
