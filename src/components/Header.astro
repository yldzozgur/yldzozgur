---
const { pathname } = Astro.url;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Ozgur Yildiz — home">
      <span class="brand-mark">OY</span>
      <span class="brand-name">Ozgur Yildiz</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" class:list={[{ active: isActive('/') }]}>Index</a>
      <a href="/writing" class:list={[{ active: isActive('/writing') }]}>Writing</a>
      <a href="/work" class:list={[{ active: isActive('/work') }]}>Work</a>
      <a href="/about" class:list={[{ active: isActive('/about') }]}>About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(14, 17, 22, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink);
    border-bottom: none;
    font-family: var(--font-display);
  }

  .brand:hover {
    border-bottom: none;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    border-radius: 3px;
  }

  .brand-name {
    font-size: 1.0625rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .site-nav {
    display: flex;
    gap: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .site-nav a {
    color: var(--ink-muted);
    border-bottom: none;
    position: relative;
    transition: color 0.2s ease;
  }

  .site-nav a:hover,
  .site-nav a.active {
    color: var(--ink);
  }

  .site-nav a.active::before {
    content: '·';
    position: absolute;
    left: -0.9rem;
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .brand-name {
      display: none;
    }
    .site-nav {
      gap: 1.25rem;
    }
  }
</style>
