---
const { pathname } = Astro.url;
const isActive = (path: string) => {
  if (path === '/') return pathname === '/';
  return pathname.startsWith(path);
};
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Ozgur Yildiz, home">
      <span class="brand-mark">OY</span>
      <span class="brand-name">ozgur yildiz</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/" class:list={[{ active: isActive('/') }]}>home</a>
      <a href="/writing" class:list={[{ active: isActive('/writing') }]}>writing</a>
      <a href="/work" class:list={[{ active: isActive('/work') }]}>work</a>
      <a href="/about" class:list={[{ active: isActive('/about') }]}>about</a>
    </nav>
    <a href="mailto:ozguryildiz0@outlook.com" class="nav-cta">say hi →</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 250, 246, 0.78);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    gap: 1rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--ink);
    border-bottom: none;
    font-weight: 700;
  }
  .brand:hover { border-bottom: none; }
  .brand-mark {
    width: 1.75rem;
    height: 1.75rem;
    background: var(--grad);
    color: white;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    letter-spacing: 0.02em;
  }
  .brand-name {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    color: var(--ink);
  }
  .site-nav {
    display: flex;
    gap: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .site-nav a {
    color: var(--ink-muted);
    border-bottom: none;
    position: relative;
    transition: color 0.15s ease;
  }
  .site-nav a:hover,
  .site-nav a.active {
    color: var(--ink);
  }
  .site-nav a.active::before {
    content: '·';
    position: absolute;
    left: -0.85rem;
    color: var(--primary);
  }
  .nav-cta {
    padding: 0.5rem 0.9rem;
    background: var(--ink);
    color: var(--bg);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 600;
    border-bottom: none;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    opacity: 0.92;
    border-bottom: none;
  }
  @media (max-width: 720px) {
    .site-nav { display: none; }
  }
</style>
