---
import BaseLayout from './BaseLayout.astro';

interface PostNav {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  readingTime?: string;
  slug: string;
  prev?: PostNav;
  next?: PostNav;
}

const { title, description, pubDate, updatedDate, tags, readingTime, slug, prev, next } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const postUrl = `https://yldzozgur.com/writing/${slug}`;
const shareText = `${title} — by Ozgur Yildiz`;
const linkedinShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
const xShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(postUrl)}`;
---

<BaseLayout title={`${title} — Ozgur Yildiz`} description={description} type="article">
  <article class="post">
    <header class="post-header container">
      <div class="post-meta">
        <time class="mono" datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime && <span class="mono dim">· {readingTime}</span>}
      </div>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      {tags.length > 0 && (
        <ul class="post-tags">
          {tags.map((tag) => (
            <li class="mono">#{tag}</li>
          ))}
        </ul>
      )}
    </header>

    <div class="container">
      <div class="prose post-content">
        <slot />
      </div>
    </div>

    {updatedDate && (
      <div class="container post-updated">
        <p class="mono dim">Last updated: {formatDate(updatedDate)}</p>
      </div>
    )}

    <div class="container post-share">
      <p class="mono dim share-label">Found this useful?</p>
      <div class="share-actions">
        <a href={linkedinShare} target="_blank" rel="noopener" class="share-btn">Share on LinkedIn ↗</a>
        <a href={xShare} target="_blank" rel="noopener" class="share-btn">Share on X ↗</a>
        <a href="/rss.xml" class="share-btn">Subscribe via RSS</a>
      </div>
    </div>

    {(prev || next) && (
      <nav class="container post-nav" aria-label="Post navigation">
        {prev ? (
          <a href={`/writing/${prev.slug}`} class="post-nav-link prev">
            <span class="mono dim">← Previous</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        ) : <span></span>}
        {next ? (
          <a href={`/writing/${next.slug}`} class="post-nav-link next">
            <span class="mono dim">Next →</span>
            <span class="post-nav-title">{next.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}

    <div class="container post-footer">
      <a href="/writing" class="back-link mono">← All writing</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding-top: 4rem;
    padding-bottom: 2.5rem;
    max-width: var(--reading-width);
    margin: 0 auto;
    border-bottom: 1px solid var(--border);
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    color: var(--ink-muted);
  }
  .post-meta .dim {
    color: var(--ink-faint);
  }
  .post-header h1 {
    margin-bottom: 1rem;
  }
  .post-description {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    line-height: 1.45;
    color: var(--ink-muted);
    font-style: italic;
  }
  .post-tags {
    list-style: none;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .post-tags li {
    color: var(--accent-dim);
  }
  .post-content {
    padding-top: 2.5rem;
  }
  .post-updated {
    max-width: var(--reading-width);
    margin: 0 auto;
    padding-top: 2rem;
  }
  .post-updated .dim {
    color: var(--ink-faint);
  }

  .post-share {
    max-width: var(--reading-width);
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .share-label {
    color: var(--ink-faint);
    margin-bottom: 0.75rem;
  }
  .share-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    color: var(--ink);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    border-bottom: 1px solid var(--border-strong);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .share-btn:hover {
    border-color: var(--accent);
    border-bottom-color: var(--accent);
    color: var(--accent);
  }

  .post-nav {
    max-width: var(--reading-width);
    margin: 2.5rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s ease;
  }
  .post-nav-link:hover {
    border-color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }
  .post-nav-link.next {
    text-align: right;
  }
  .post-nav-link .dim {
    color: var(--ink-faint);
    font-size: 0.75rem;
  }
  .post-nav-title {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-footer {
    max-width: var(--reading-width);
    margin: 2.5rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .back-link {
    color: var(--ink-muted);
    border-bottom: none;
  }
  .back-link:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-link.next {
      text-align: left;
    }
  }
</style>
