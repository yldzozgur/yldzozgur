---
import BaseLayout from './BaseLayout.astro';

interface PostNav {
  slug: string;
  title: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags: string[];
  readingTime?: string;
  slug: string;
  prev?: PostNav;
  next?: PostNav;
}

const { title, description, pubDate, updatedDate, tags, readingTime, slug, prev, next } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const postUrl = `https://yldzozgur.com/writing/${slug}`;
const shareText = `${title} — by Ozgur Yildiz`;
const linkedinShare = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`;
const xShare = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(postUrl)}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: 'Ozgur Yildiz',
    url: 'https://yldzozgur.com',
  },
  publisher: {
    '@type': 'Person',
    name: 'Ozgur Yildiz',
  },
  url: postUrl,
  mainEntityOfPage: postUrl,
  keywords: tags.join(', '),
  image: 'https://yldzozgur.com/og-default.png',
};
---

<BaseLayout title={`${title} — Ozgur Yildiz`} description={description} type="article" jsonLd={articleLd}>
  <article class="post">
    <header class="post-header container">
      <div class="post-meta">
        <time class="mono" datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime && <span class="mono dim">· {readingTime}</span>}
      </div>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      {tags.length > 0 && (
        <ul class="post-tags">
          {tags.map((tag) => (
            <li><a class="mono tag-link" href={`/writing/tags/${tag}`}>#{tag}</a></li>
          ))}
        </ul>
      )}
    </header>

    <div class="container">
      <div class="prose post-content">
        <slot />
      </div>
    </div>

    {updatedDate && (
      <div class="container post-updated">
        <p class="mono dim">Last updated: {formatDate(updatedDate)}</p>
      </div>
    )}

    <div class="container post-share">
      <p class="mono dim share-label">Found this useful? Pass it on.</p>
      <div class="share-actions">
        <a href={linkedinShare} target="_blank" rel="noopener" class="share-btn share-linkedin" aria-label="Share on LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          <span>Share on LinkedIn</span>
        </a>
        <a href={xShare} target="_blank" rel="noopener" class="share-btn share-x" aria-label="Share on X">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          <span>Share on X</span>
        </a>
        <button type="button" class="share-btn share-copy copy-btn" data-url={postUrl} aria-label="Copy link to clipboard">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          <span class="copy-label">Copy link</span>
        </button>
        <a href="/rss.xml" class="share-btn share-rss" aria-label="Subscribe via RSS">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20A2.18 2.18 0 0 1 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          <span>RSS</span>
        </a>
      </div>
    </div>

    <script is:inline>
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const url = btn.getAttribute('data-url');
          try {
            await navigator.clipboard.writeText(url);
            const original = btn.textContent;
            btn.textContent = 'Copied ✓';
            setTimeout(() => { btn.textContent = original; }, 1500);
          } catch (e) {
            btn.textContent = 'Copy failed';
          }
        });
      });
    </script>

    {(prev || next) && (
      <nav class="container post-nav" aria-label="Post navigation">
        {prev ? (
          <a href={`/writing/${prev.slug}`} class="post-nav-link prev">
            <span class="mono dim">← Previous</span>
            <span class="post-nav-title">{prev.title}</span>
          </a>
        ) : <span></span>}
        {next ? (
          <a href={`/writing/${next.slug}`} class="post-nav-link next">
            <span class="mono dim">Next →</span>
            <span class="post-nav-title">{next.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}

    <div class="container post-footer">
      <a href="/writing" class="back-link mono">← All writing</a>
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding-top: 4rem;
    padding-bottom: 2.5rem;
    max-width: var(--reading-width);
    margin: 0 auto;
    border-bottom: 1px solid var(--border);
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    color: var(--ink-muted);
  }
  .post-meta .dim {
    color: var(--ink-faint);
  }
  .post-header h1 {
    margin-bottom: 1rem;
  }
  .post-description {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    line-height: 1.45;
    color: var(--ink-muted);
    font-style: italic;
  }
  .post-tags {
    list-style: none;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .post-tags li {
    color: var(--accent-dim);
  }
  .tag-link {
    color: var(--accent-dim);
    border-bottom: none;
  }
  .tag-link:hover {
    color: var(--accent);
    border-bottom: 1px solid var(--accent);
  }
  .post-content {
    padding-top: 2.5rem;
  }
  .post-updated {
    max-width: var(--reading-width);
    margin: 0 auto;
    padding-top: 2rem;
  }
  .post-updated .dim {
    color: var(--ink-faint);
  }

  .post-share {
    max-width: var(--reading-width);
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .share-label {
    color: var(--ink-faint);
    margin-bottom: 0.75rem;
  }
  .share-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    color: var(--ink);
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    background: transparent;
    cursor: pointer;
    border-bottom: 1px solid var(--border-strong);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  .share-btn svg {
    flex-shrink: 0;
    transition: color 0.2s ease;
  }
  .share-linkedin svg { color: #0A66C2; }
  .share-x svg { color: #000; }
  .share-rss svg { color: #EE802F; }
  .share-btn:hover {
    border-color: var(--accent);
    border-bottom-color: var(--accent);
    color: var(--accent);
  }
  .share-linkedin:hover { border-color: #0A66C2; border-bottom-color: #0A66C2; color: #0A66C2; }
  .share-x:hover { border-color: #000; border-bottom-color: #000; color: #000; }
  .share-rss:hover { border-color: #EE802F; border-bottom-color: #EE802F; color: #EE802F; }

  .post-nav {
    max-width: var(--reading-width);
    margin: 2.5rem auto 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s ease;
  }
  .post-nav-link:hover {
    border-color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .post-nav-link:hover .post-nav-title {
    color: var(--accent);
  }
  .post-nav-link.next {
    text-align: right;
  }
  .post-nav-link .dim {
    color: var(--ink-faint);
    font-size: 0.75rem;
  }
  .post-nav-title {
    font-family: var(--font-display);
    font-size: 1rem;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-footer {
    max-width: var(--reading-width);
    margin: 2.5rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .back-link {
    color: var(--ink-muted);
    border-bottom: none;
  }
  .back-link:hover {
    color: var(--accent);
  }

  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }
    .post-nav-link.next {
      text-align: left;
    }
  }
</style>
