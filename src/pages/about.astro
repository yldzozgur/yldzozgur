---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  Languages: ['JavaScript (ES6+)', 'TypeScript', 'SQL', 'HTML5', 'CSS3'],
  Frontend: ['React', 'Redux Toolkit', 'React Router', 'Vite', 'Tailwind CSS', 'MUI'],
  Backend: ['Node.js', 'Express', 'REST APIs', 'JWT', 'Mongoose', 'Swagger / OpenAPI'],
  Databases: ['PostgreSQL', 'MongoDB', 'MySQL'],
  'Cloud & DevOps': ['Vercel', 'Docker', 'GitHub Actions'],
  Testing: ['Cypress (E2E)'],
  'AI-Assisted Workflow': ['Claude Code', 'Cursor', 'GitHub Copilot'],
};
---

<BaseLayout
  title="About — Ozgur Yildiz"
  description="An engineer's notes on reading code, writing small PRs, and the slow parts of software."
>
  <section class="page-header container">
    <span class="mono dim">/ about</span>
    <h1>About</h1>
  </section>

  <section class="container">
    <div class="prose about-prose">
      <p class="lead">
        I like the slow parts of software.
      </p>

      <p>
        Reading the code that's already there before writing new code. Asking
        <em>why</em> before <em>how</em>. Finishing things — including the boring
        bits, the docs, the error messages no one reads until they need them.
      </p>

      <p>
        What I value in engineering: small pull requests you can review in ten
        minutes, error messages that point at the cause and not the symptom, and
        tests that fail loudly when they should. I'd rather understand a system
        slowly than ship something I can't defend in code review.
      </p>

      <p>
        I write here mostly to think out loud — explaining something forces me
        to actually understand it. This site itself was built in an afternoon
        with Astro and Cloudflare Workers; the unglamorous parts of that are
        already in <a href="/writing">/writing</a>'s backlog.
      </p>

      <p>
        For role conversations and full career history →
        <a href="https://linkedin.com/in/yldzozgur">LinkedIn</a> or
        <a href="mailto:ozguryildiz0@outlook.com">email</a>.
      </p>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Stack</h2>
    <dl class="skills">
      {Object.entries(skills).map(([category, items]) => (
        <div class="skill-row">
          <dt class="mono skill-cat">{category}</dt>
          <dd>
            <ul class="skill-list">
              {items.map((item) => (
                <li class="mono skill-item">{item}</li>
              ))}
            </ul>
          </dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Find me</h2>
    <div class="activity-grid">
      <a href="https://github.com/yldzozgur" target="_blank" rel="noopener" class="activity-card">
        <span class="mono activity-label">GitHub</span>
        <span class="activity-title">github.com/yldzozgur ↗</span>
        <span class="activity-note">Where the code lives.</span>
      </a>
      <a href="https://linkedin.com/in/yldzozgur" target="_blank" rel="noopener" class="activity-card">
        <span class="mono activity-label">LinkedIn</span>
        <span class="activity-title">linkedin.com/in/yldzozgur ↗</span>
        <span class="activity-note">The long-form career story.</span>
      </a>
      <a href="/writing" class="activity-card">
        <span class="mono activity-label">Writing</span>
        <span class="activity-title">/writing →</span>
        <span class="activity-note">Words I've left lying around.</span>
      </a>
      <a href="/work" class="activity-card">
        <span class="mono activity-label">Work</span>
        <span class="activity-title">/work →</span>
        <span class="activity-note">Things I've shipped, mostly live.</span>
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 1.5rem;
    max-width: 48rem;
  }
  .page-header .dim {
    color: var(--ink-faint);
  }
  .page-header h1 {
    margin: 0.5rem 0 0;
  }

  .about-prose {
    padding-top: 1rem;
  }
  .about-prose .lead {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .about-prose p {
    color: var(--ink-muted);
  }
  .about-prose strong {
    color: var(--ink);
    font-weight: 600;
  }

  .section-block {
    margin-top: 4rem;
  }
  .section-heading {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }

  .skills {
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }
  .skill-row:last-child {
    border-bottom: none;
  }
  .skill-cat {
    color: var(--accent-dim);
    padding-top: 0.2rem;
  }
  .skill-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .skill-item {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    color: var(--ink-muted);
    font-size: 0.75rem;
    text-transform: none;
  }

  .activity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .activity-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--bg-subtle);
    color: var(--ink);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .activity-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .activity-label {
    color: var(--accent-dim);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .activity-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink);
  }
  .activity-card:hover .activity-title {
    color: var(--accent);
  }
  .activity-note {
    color: var(--ink-muted);
    font-size: 0.8125rem;
  }
  @media (max-width: 640px) {
    .activity-grid {
      grid-template-columns: 1fr;
    }
    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  .contact {
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }
  .contact p {
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }
  .contact-list {
    list-style: none;
  }
  .contact-list li {
    padding: 0.4rem 0;
  }
  .contact-list a {
    color: var(--accent);
  }
</style>
