---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  Languages: ['JavaScript (ES6+)', 'TypeScript', 'SQL', 'HTML5', 'CSS3'],
  Frontend: ['React', 'Redux Toolkit', 'React Router', 'Vite', 'Tailwind CSS', 'MUI'],
  Backend: ['Node.js', 'Express', 'REST APIs', 'JWT', 'Mongoose', 'Swagger / OpenAPI'],
  Databases: ['PostgreSQL', 'MongoDB', 'MySQL'],
  'Cloud & DevOps': ['Vercel', 'Docker', 'GitHub Actions', 'CI/CD'],
  Testing: ['Cypress (E2E)'],
  'AI-Assisted Workflow': ['Claude Code', 'Codex'],
};
---

<BaseLayout
  title="About | Ozgur Yildiz"
  description="A bit about Ozgur Yildiz, a full-stack developer in Austin, and the tools he works with."
>
  <section class="page-header container">
    <span class="mono dim">/ about</span>
    <h1>About</h1>
  </section>

  <section class="container">
    <div class="prose about-prose">
      <p class="lead">
        Hi, I'm Ozgur. I'm a full-stack developer in Austin, looking for my
        first developer role.
      </p>

      <p>
        Most of what I build is React on the front end and Node/Express on the
        back. I've put together a few full apps with auth, a database, and a
        REST API, so I'm comfortable taking a feature from nothing to working
        software. There's still a lot I'm learning, mostly around performance
        and the kind of bugs that only show up once something is live.
      </p>

      <p>
        I came to software later than a lot of people. I ran a small business
        for a few years before this, which taught me to ship things instead of
        polishing them forever. I'm not precious about my code. I read what's
        already there before I change it, and I ask questions when something
        doesn't make sense instead of guessing my way through it.
      </p>

      <p>
        This site is where I write things down, partly for myself and partly
        so there's something to point at.
      </p>

      <p>
        Want to talk? Find me on
        <a href="https://linkedin.com/in/yldzozgur">LinkedIn</a> or send me an
        <a href="mailto:ozguryildiz0@outlook.com">email</a>.
      </p>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Stack</h2>
    <dl class="skills">
      {Object.entries(skills).map(([category, items]) => (
        <div class="skill-row">
          <dt class="mono skill-cat">{category}</dt>
          <dd>
            <ul class="skill-list">
              {items.map((item) => (
                <li class="mono skill-item">{item}</li>
              ))}
            </ul>
          </dd>
        </div>
      ))}
    </dl>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 1.5rem;
    max-width: 48rem;
  }
  .page-header .dim {
    color: var(--ink-faint);
  }
  .page-header h1 {
    margin: 0.5rem 0 0;
  }

  .about-prose {
    padding-top: 1rem;
  }
  .about-prose .lead {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .about-prose p {
    color: var(--ink-muted);
  }
  .about-prose strong {
    color: var(--ink);
    font-weight: 600;
  }

  .section-block {
    margin-top: 4rem;
  }
  .section-heading {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }

  .skills {
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }
  .skill-row:last-child {
    border-bottom: none;
  }
  .skill-cat {
    color: var(--accent-dim);
    padding-top: 0.2rem;
  }
  .skill-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .skill-item {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    color: var(--ink-muted);
    font-size: 0.75rem;
    text-transform: none;
  }

  .activity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .activity-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--bg-subtle);
    color: var(--ink);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .activity-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .activity-label {
    color: var(--accent-dim);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .activity-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink);
  }
  .activity-card:hover .activity-title {
    color: var(--accent);
  }
  .activity-note {
    color: var(--ink-muted);
    font-size: 0.8125rem;
  }
  @media (max-width: 640px) {
    .activity-grid {
      grid-template-columns: 1fr;
    }
    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  .contact {
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }
  .contact p {
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }
  .contact-list {
    list-style: none;
  }
  .contact-list li {
    padding: 0.4rem 0;
  }
  .contact-list a {
    color: var(--accent);
  }
</style>
