---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills = {
  Languages: ['JavaScript (ES6+)', 'TypeScript', 'SQL', 'HTML5', 'CSS3'],
  'Frontend / Mobile': ['React', 'React Native (iOS)', 'Redux Toolkit', 'Vite', 'Tailwind CSS', 'MUI', 'Formik/Yup'],
  Backend: ['Node.js', 'Express', 'REST APIs', 'JWT', 'Mongoose', 'Swagger / OpenAPI', 'Multer', 'Nodemailer'],
  Databases: ['PostgreSQL', 'MongoDB'],
  'AI / Speech': ['OpenAI API', 'Gemini API', 'Speech-to-Text', 'Speaker Diarization', 'Text-to-Speech', 'WebSocket'],
  'Cloud & Auth': ['Vercel', 'MongoDB Atlas', 'Firebase Auth'],
  'Tools & DevOps': ['Docker', 'Git / GitHub', 'CI/CD (GitHub Actions)', 'GitHub Pages', 'Postman', 'npm', 'Linux / Bash'],
  Testing: ['Cypress (E2E)'],
};
---

<BaseLayout
  title="About | Ozgur Yildiz"
  description="A bit about Ozgur Yildiz, a full-stack developer in Austin, and the tools he works with."
>
  <section class="page-header container">
    <span class="mono dim">/ about</span>
    <h1>About</h1>
  </section>

  <section class="container">
    <div class="prose about-prose">
      <p class="lead">
        Hi, I'm Ozgur. Full-Stack Developer based in Austin, TX.
      </p>

      <p>
        Currently building a React Native iOS app that streams live audio over WebSocket and renders real-time STT transcripts, speaker-attributed diarization output, and AI-generated suggestions at Guinn Partners. I also manage a Node.js server on embedded Linux handling concurrent I/O from microphone, camera, and speaker peripherals.
      </p>

      <p>
        Previously contributed 100+ merged PRs to a production multi-tenant POS platform at Ameza Solutions across a React + TypeScript frontend and Node / Express + PostgreSQL backend. Built employee and store dashboards, role-catalog APIs with typed DTOs, and automated Swagger snapshot sync.
      </p>

      <p>
        Completed a full-stack bootcamp (Clarusway, 2024) covering Node.js, Express, React, TypeScript, PostgreSQL, MongoDB, and Docker. Live portfolio includes a full-stack MERN dashboard, two REST APIs with Swagger UI, and a Firebase-authenticated SPA.
      </p>

      <p>
        Work Authorization: Authorized to work in the U.S. No sponsorship required, now or in the future.
        Available for Full-Stack and Backend roles — Remote (US-wide), Hybrid, or On-site (Greater Austin).
      </p>

      <p>
        Want to talk? Find me on
        <a href="https://linkedin.com/in/yldzozgur">LinkedIn</a> or send me an
        <a href="mailto:ozgur@yldzozgur.com">email</a>.
      </p>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Experience</h2>
    <div class="exp-list">
      <div class="exp-entry">
        <div class="exp-header">
          <div>
            <h3 class="exp-company">Guinn Partners</h3>
            <p class="exp-title">Full-Stack Developer &mdash; On-site, Austin, TX</p>
          </div>
          <span class="mono exp-period">Feb 2025 &ndash; Present</span>
        </div>
        <ul class="exp-bullets">
          <li>Developing a React Native iOS app that streams live audio over WebSocket and renders STT transcripts, speaker-attributed diarization output, and AI-generated suggestions in real time.</li>
          <li>Building a Node.js server on embedded Linux managing concurrent I/O from microphone, camera, and speaker peripherals while maintaining a persistent WebSocket tunnel to a cloud backend.</li>
          <li>Integrating OpenAI and Gemini APIs into a multi-stage AI pipeline (STT &rarr; speaker diarization &rarr; LLM inference &rarr; TTS), optimizing end-to-end response latency across network and inference hops.</li>
          <li>Designing the full-stack session architecture: audio capture, cloud routing, AI orchestration, and mobile playback, spanning hardware layer to UI.</li>
        </ul>
      </div>
      <div class="exp-entry">
        <div class="exp-header">
          <div>
            <h3 class="exp-company">Ameza Solutions</h3>
            <p class="exp-title">Full-Stack Developer &mdash; Remote, Austin, TX</p>
          </div>
          <span class="mono exp-period">Oct 2024 &ndash; Feb 2025</span>
        </div>
        <ul class="exp-bullets">
          <li>Contributed 100+ merged PRs to a production multi-tenant POS platform across a React + TypeScript frontend and Node / Express + PostgreSQL backend in a fast-moving feature-branch workflow.</li>
          <li>Built and iterated on employee and store dashboards, role-catalog APIs with typed DTOs, input validation utilities, and automated Swagger snapshot sync to keep API contracts in lockstep with implementation.</li>
          <li>Participated in structured code review cycles, catching type safety issues and API contract drift before merge in a small distributed team.</li>
          <li>Leveraged AI-assisted tooling to accelerate delivery without sacrificing code ownership or review quality.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Education</h2>
    <div class="edu-list">
      <div class="edu-entry">
        <span class="mono exp-period">Feb 2024 &ndash; Oct 2024</span>
        <div>
          <p class="edu-degree">Full Stack Development Bootcamp &mdash; Clarusway</p>
          <p class="edu-note">Node, Express, React, TypeScript, MongoDB, PostgreSQL, Docker, JWT, Cypress</p>
        </div>
      </div>
      <div class="edu-entry">
        <span class="mono exp-period">2023 &ndash; 2025</span>
        <div>
          <p class="edu-degree">M.B.A. &mdash; Marmara University</p>
        </div>
      </div>
      <div class="edu-entry">
        <span class="mono exp-period">2020 &ndash; 2023</span>
        <div>
          <p class="edu-degree">B.S. Computer Engineering &mdash; Cumhuriyet University, Turkey</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container section-block">
    <h2 class="section-heading">Stack</h2>
    <dl class="skills">
      {Object.entries(skills).map(([category, items]) => (
        <div class="skill-row">
          <dt class="mono skill-cat">{category}</dt>
          <dd>
            <ul class="skill-list">
              {items.map((item) => (
                <li class="mono skill-item">{item}</li>
              ))}
            </ul>
          </dd>
        </div>
      ))}
    </dl>
  </section>

</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 1.5rem;
    max-width: 48rem;
  }
  .page-header .dim {
    color: var(--ink-faint);
  }
  .page-header h1 {
    margin: 0.5rem 0 0;
  }

  .about-prose {
    padding-top: 1rem;
  }
  .about-prose .lead {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.45;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  .about-prose p {
    color: var(--ink-muted);
  }
  .about-prose strong {
    color: var(--ink);
    font-weight: 600;
  }

  .section-block {
    margin-top: 4rem;
  }
  .section-heading {
    font-size: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.75rem;
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }

  .skills {
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .skill-row {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }
  .skill-row:last-child {
    border-bottom: none;
  }
  .skill-cat {
    color: var(--accent-dim);
    padding-top: 0.2rem;
  }
  .skill-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .skill-item {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
    color: var(--ink-muted);
    font-size: 0.75rem;
    text-transform: none;
  }

  .activity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .activity-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 5px;
    background: var(--bg-subtle);
    color: var(--ink);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .activity-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .activity-label {
    color: var(--accent-dim);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .activity-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--ink);
  }
  .activity-card:hover .activity-title {
    color: var(--accent);
  }
  .activity-note {
    color: var(--ink-muted);
    font-size: 0.8125rem;
  }
  @media (max-width: 640px) {
    .activity-grid {
      grid-template-columns: 1fr;
    }
    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  .exp-list, .edu-list {
    max-width: var(--reading-width);
    margin: 0 auto;
  }
  .exp-entry {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--border);
  }
  .exp-entry:last-child { border-bottom: none; }
  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .exp-company {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.2rem;
    color: var(--ink);
  }
  .exp-title {
    color: var(--ink-muted);
    font-size: 0.9rem;
    margin: 0;
  }
  .exp-period {
    color: var(--ink-faint);
    font-size: 0.8rem;
    white-space: nowrap;
    padding-top: 0.15rem;
  }
  .exp-bullets {
    color: var(--ink-muted);
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 1.25rem;
  }
  .exp-bullets li { margin-bottom: 0.4rem; }
  .edu-entry {
    display: flex;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }
  .edu-entry:last-child { border-bottom: none; }
  .edu-degree {
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.2rem;
    font-size: 0.9375rem;
  }
  .edu-note {
    color: var(--ink-muted);
    font-size: 0.8125rem;
    margin: 0;
  }

  .contact {
    max-width: var(--reading-width);
    margin-left: auto;
    margin-right: auto;
  }
  .contact p {
    color: var(--ink-muted);
    margin-bottom: 1rem;
  }
  .contact-list {
    list-style: none;
  }
  .contact-list li {
    padding: 0.4rem 0;
  }
  .contact-list a {
    color: var(--accent);
  }
</style>
