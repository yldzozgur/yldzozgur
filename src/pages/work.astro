---
import BaseLayout from '@/layouts/BaseLayout.astro';

const projects = [
  {
    name: 'Stock Management App',
    type: 'Full-Stack · MERN',
    stack: ['React', 'Redux Toolkit', 'Vite', 'Express', 'MongoDB', 'JWT', 'Tailwind', 'MUI', 'Recharts'],
    summary: 'Full-stack inventory + sales platform: JWT auth, role-based permissions, image upload, email verification, Swagger / Redoc docs. Backend: Express + Mongoose REST API with a layered middleware suite covering auth, error handling, logging, permissions, and file upload. Frontend: Vite + React + Redux Toolkit dashboard with KPI cards, Recharts, custom hooks, Tailwind + MUI styling.',
    thumb: '/projects/stock-management.webp',
    links: [
      { label: 'Live demo →', href: 'https://ozguryildiz-stock.vercel.app' },
      { label: 'API →', href: 'https://ozguryildiz-stock-api.vercel.app' },
      { label: 'Code →', href: 'https://github.com/yldzozgur/stock-management-app' },
    ],
  },
  {
    name: 'React Movie App',
    type: 'Frontend · Firebase Auth SPA',
    stack: ['React', 'Firebase Auth', 'TMDB API'],
    summary: 'Movie discovery SPA with email/password and Google OAuth sign-in via Firebase; consumes the TMDB REST API for live movie data. Implemented protected routes, persistent auth state, and search + genre filtering with a responsive UI.',
    thumb: '/projects/react-movieapp.webp',
    links: [
      { label: 'Live →', href: 'https://yldzozgur.github.io/react-movieapp/' },
      { label: 'Code →', href: 'https://github.com/yldzozgur/react-movieapp' },
    ],
  },
  {
    name: 'Pizza API',
    type: 'Backend · REST + Swagger',
    stack: ['Express', 'MongoDB', 'JWT', 'Multer', 'Swagger', 'Vercel'],
    summary: 'REST API focused on file handling and API infrastructure: Multer-based image upload, email verification, and CDN-hosted Swagger UI with full OpenAPI documentation. Pagination / sorting / filtering middleware and centralized error handling; deployed on Vercel serverless with MongoDB Atlas.',
    thumb: '/projects/pizza-api.webp',
    links: [
      { label: 'Live API →', href: 'https://ozguryildiz-pizza-api.vercel.app' },
      { label: 'Swagger →', href: 'https://ozguryildiz-pizza-api.vercel.app/documents/swagger' },
      { label: 'Code →', href: 'https://github.com/yldzozgur/pizza-api' },
    ],
  },
  {
    name: 'Rent-A-Car API',
    type: 'Backend · REST + Swagger',
    stack: ['Express', 'MongoDB', 'JWT', 'Nodemailer', 'Swagger', 'Vercel'],
    summary: 'REST API focused on business logic: date-overlap detection to prevent double bookings, automatic rental amount calculation, and unique-field validation. JWT auth, email notifications, and Swagger docs; deployed on Vercel serverless with MongoDB Atlas.',
    thumb: '/projects/rentacar-api.webp',
    links: [
      { label: 'Live API →', href: 'https://ozguryildiz-rentacar-api.vercel.app' },
      { label: 'Swagger →', href: 'https://ozguryildiz-rentacar-api.vercel.app/document/swagger' },
      { label: 'Code →', href: 'https://github.com/yldzozgur/rent-a-car-api' },
    ],
  },
];

const demoNote = 'Demo credentials for all live API / full-stack demos: demo@demo.com / Demo1234!';
---

<BaseLayout
  title="Work | Ozgur Yildiz"
  description="Things I've built: open source, mostly live, all clickable."
>
  <section class="page-header container">
    <span class="mono dim">/ work</span>
    <h1>Work</h1>
    <p class="page-lede">
      Click any card to see the thing running. Code links live next to each one.
    </p>
    <p class="demo-note mono">{demoNote}</p>
  </section>

  <section class="container">
    <ul class="projects">
      {projects.map((p, i) => (
        <li class="project">
          <div class="project-index mono">{String(i + 1).padStart(2, '0')}</div>
          <div class="project-body">
            <header class="project-header">
              <h2 class="project-name">{p.name}</h2>
            </header>
            <p class="mono project-type">{p.type}</p>
            <ul class="stack">
              {p.stack.map((s) => <li class="mono stack-tag">{s}</li>)}
            </ul>
            <p class="project-summary">{p.summary}</p>
            {p.thumb && (
              <a class="project-thumb" href={p.links[0].href} target="_blank" rel="noopener" aria-label={`${p.name} live preview`}>
                <img src={p.thumb} alt={`${p.name} screenshot`} loading="lazy" decoding="async" width="1200" height="800" />
                <span class="project-thumb-overlay mono">Open live →</span>
              </a>
            )}
            <ul class="project-links">
              {p.links.map((l) => (
                <li>
                  <a href={l.href} target="_blank" rel="noopener" class="mono">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 2.5rem;
    max-width: 48rem;
  }
  .page-header .dim {
    color: var(--ink-faint);
  }
  .page-header h1 {
    margin: 0.5rem 0 1.25rem;
  }
  .page-lede {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    line-height: 1.5;
    color: var(--ink-muted);
    font-style: italic;
    margin-bottom: 1.5rem;
  }
  .demo-note {
    color: var(--accent-dim);
    background: var(--bg-subtle);
    padding: 0.75rem 1rem;
    border-left: 2px solid var(--accent);
    border-radius: 0 4px 4px 0;
    font-size: 0.8125rem;
    text-transform: none;
  }

  .projects {
    list-style: none;
    border-top: 1px solid var(--border);
  }
  .project {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .project-index {
    color: var(--ink-faint);
    font-size: 0.9375rem;
    padding-top: 0.4rem;
  }
  .project-body {
    min-width: 0;
  }
  .project-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .project-name {
    font-family: var(--font-display);
    font-size: 1.625rem;
    line-height: 1.2;
  }
  .project-period {
    color: var(--ink-faint);
    flex-shrink: 0;
  }
  .project-type {
    color: var(--accent-dim);
    margin-bottom: 1rem;
  }
  .stack {
    list-style: none;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .stack-tag {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    color: var(--ink-muted);
    font-size: 0.75rem;
    text-transform: none;
  }
  .project-summary {
    color: var(--ink-muted);
    margin-bottom: 1.25rem;
    max-width: 40rem;
  }
  .project-thumb {
    display: block;
    position: relative;
    max-width: 36rem;
    margin: 0 0 1.25rem;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: border-color 0.25s ease, transform 0.25s ease;
  }
  .project-thumb img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    object-position: top;
    filter: saturate(0.92);
    transition: filter 0.3s ease, transform 0.4s ease;
  }
  .project-thumb:hover {
    border-color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .project-thumb:hover img {
    filter: saturate(1.05);
    transform: scale(1.02);
  }
  .project-thumb-overlay {
    position: absolute;
    right: 0.75rem;
    bottom: 0.75rem;
    padding: 0.35rem 0.6rem;
    background: rgba(14, 17, 22, 0.85);
    color: var(--accent);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 3px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .project-thumb:hover .project-thumb-overlay {
    opacity: 1;
    transform: translateY(0);
  }
  .project-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .project-links a {
    color: var(--accent);
    border-bottom: none;
  }
  .project-links a:hover {
    color: var(--link);
  }

  @media (max-width: 640px) {
    .project {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .project-index {
      padding-top: 0;
    }
  }
</style>
