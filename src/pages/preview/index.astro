    <script is:inline>
      // mouse spotlight (subtle)
      const sp = document.getElementById('spotlight');
      if (sp && window.matchMedia('(min-width: 720px)').matches) {
        document.addEventListener('mousemove', (e) => {
          sp.style.setProperty('--mx', e.clientX + 'px');
          sp.style.setProperty('--my', e.clientY + 'px');
        });
      }
      // simple reveal on scroll (initial state always visible — only enhances)
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
      document.querySelectorAll('.card, .work-tile, .work-feat, .writing-row, .cta-card').forEach(el => io.observe(el));
    </script>

    <style is:global>
      :root {
        --bg: #fafaf6;
        --bg-soft: #f4f3ed;
        --bg-card: #ffffff;
        --bg-card-hover: #fafaf6;
        --border: #e8e6df;
        --border-strong: #d4d1c8;
        --ink: #18181b;
        --ink-mute: #52525b;
        --ink-faint: #a1a1aa;
        --primary: #4f46e5;
        --primary-soft: #eef2ff;
        --warm: #f97316;
        --warm-soft: #fff7ed;
        --success: #10b981;
        --grad: linear-gradient(135deg, #6366f1 0%, #ec4899 100%);
        --font: 'Inter', system-ui, -apple-system, sans-serif;
        --display: 'Onest', 'Inter', system-ui, sans-serif;
        --mono: 'JetBrains Mono', monospace;
        --radius: 16px;
        --radius-sm: 10px;
        --shadow-sm: 0 1px 2px rgba(24, 24, 27, 0.04);
        --shadow: 0 6px 24px -8px rgba(24, 24, 27, 0.08);
        --shadow-lg: 0 24px 60px -20px rgba(24, 24, 27, 0.12);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.55;
        overflow-x: hidden;
        position: relative;
      }
      a { color: inherit; text-decoration: none; }
      .container { max-width: 1240px; margin: 0 auto; padding: 0 1.5rem; }
      .mono { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.01em; }
      .dim { color: var(--ink-faint); }
      .accent { color: var(--primary); }
      .link {
        color: var(--primary);
        font-weight: 500;
        border-bottom: 1px solid currentColor;
        padding-bottom: 1px;
      }
      .link:hover { color: var(--ink); border-color: var(--ink); }
      code { font-family: var(--mono); font-size: 0.85em; background: var(--bg-soft); padding: 0.1rem 0.35rem; border-radius: 4px; color: var(--primary); }
      strong { font-weight: 600; color: var(--ink); }

      h1, h2, h3, h4 { font-family: var(--display); letter-spacing: -0.025em; line-height: 1.05; font-weight: 800; }
      h3 { font-size: 1.0625rem; letter-spacing: -0.01em; }
      h4 { font-size: 1rem; letter-spacing: -0.01em; }

      /* ===== spotlight ===== */
      .spotlight {
        position: fixed; inset: 0;
        pointer-events: none;
        z-index: 1;
        background: radial-gradient(560px circle at var(--mx, 50%) var(--my, 50%), rgba(99, 102, 241, 0.08), transparent 60%);
        opacity: 0.7;
        transition: background 0.05s linear;
      }

      /* ===== nav ===== */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(250, 250, 246, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        max-width: 1240px; margin: 0 auto;
        padding: 0.9rem 1.5rem;
        display: flex; justify-content: space-between; align-items: center;
        gap: 1rem;
      }
      .brand { display: flex; align-items: center; gap: 0.65rem; font-weight: 700; }
      .brand-mark {
        width: 1.75rem; height: 1.75rem;
        background: var(--grad);
        color: white;
        font-family: var(--mono);
        font-size: 0.6875rem;
        font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 6px;
      }
      .brand-name { font-family: var(--display); font-size: 1.0625rem; }
      .nav-links { display: flex; gap: 1.75rem; font-family: var(--mono); font-size: 0.8125rem; }
      .nav-links a { color: var(--ink-mute); transition: color 0.15s; }
      .nav-links a:hover { color: var(--ink); }
      .nav-cta {
        padding: 0.5rem 0.875rem;
        font-size: 0.8125rem;
        font-weight: 600;
        background: var(--ink);
        color: var(--bg);
        border-radius: 999px;
        transition: transform 0.2s, opacity 0.2s;
      }
      .nav-cta:hover { transform: translateY(-1px); opacity: 0.92; }
      @media (max-width: 720px) { .nav-links { display: none; } }

      /* ===== hero ===== */
      .hero { padding: 5rem 1.5rem 4rem; position: relative; z-index: 2; }
      .hero-grid {
        max-width: 1240px; margin: 0 auto;
        display: grid; grid-template-columns: 1.05fr 1fr;
        gap: 4rem; align-items: center;
      }
      .kicker {
        display: inline-flex; align-items: center; gap: 0.55rem;
        background: rgba(16, 185, 129, 0.1);
        color: #047857;
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
        font-size: 0.8125rem;
        font-weight: 500;
        margin-bottom: 2rem;
        border: 1px solid rgba(16, 185, 129, 0.2);
      }
      .kicker .dot {
        width: 6px; height: 6px;
        background: var(--success);
        border-radius: 50%;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.2);
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse { 50% { opacity: 0.45; } }

      .display {
        font-size: clamp(2.75rem, 6vw, 4.75rem);
        font-weight: 900;
        letter-spacing: -0.04em;
        margin-bottom: 1.75rem;
      }
      .display .accent {
        background: var(--grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .hero-lede {
        font-size: 1.0625rem;
        color: var(--ink-mute);
        max-width: 32rem;
        margin-bottom: 2rem;
      }
      .hero-cta { display: flex; gap: 0.65rem; flex-wrap: wrap; }
      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.7rem 1.1rem;
        font-size: 0.9375rem;
        font-weight: 600;
        border-radius: 10px;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s, background 0.2s;
      }
      .btn-primary {
        background: var(--ink);
        color: var(--bg);
      }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
      .btn-ghost {
        background: var(--bg-card);
        color: var(--ink);
        border: 1px solid var(--border);
      }
      .btn-ghost:hover { background: var(--bg-card-hover); border-color: var(--border-strong); transform: translateY(-1px); }

      /* terminal */
      .terminal {
        background: #18181b;
        color: #e4e4e7;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 24px 60px -20px rgba(24, 24, 27, 0.25), 0 0 0 1px rgba(24, 24, 27, 0.06);
        font-family: var(--mono);
        font-size: 0.8125rem;
        line-height: 1.7;
      }
      .terminal-bar {
        display: flex; align-items: center; gap: 0.4rem;
        padding: 0.65rem 0.9rem;
        background: #27272a;
        border-bottom: 1px solid #3f3f46;
      }
      .t-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
      .dr { background: #ff5f57; } .dy { background: #febc2e; } .dg { background: #28c840; }
      .t-name { margin-left: 0.75rem; color: #a1a1aa; font-size: 0.7rem; }
      .t-body { padding: 1rem 1.25rem 1.25rem; margin: 0; overflow-x: auto; }
      .t-body code { background: none; color: inherit; padding: 0; font-size: inherit; }
      .t-prompt { color: #34d399; }
      .t-c { color: #a78bfa; }
      .t-out { color: #d4d4d8; }
      .t-ok { color: #34d399; }
      .t-cursor { color: #fbbf24; animation: blink 1s steps(2, start) infinite; }
      @keyframes blink { to { visibility: hidden; } }

      /* ===== sections ===== */
      .section { padding: 5rem 1.5rem; position: relative; z-index: 2; }
      .section-alt { background: var(--bg-soft); }
      .section-head { margin-bottom: 2.5rem; }
      .section-title {
        font-size: clamp(2rem, 4vw, 3.25rem);
        font-weight: 900;
        letter-spacing: -0.03em;
        margin-bottom: 0.5rem;
      }
      .section-sub { color: var(--ink-mute); font-size: 1rem; max-width: 38rem; }

      /* ===== BENTO ===== */
      .bento {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: minmax(170px, auto);
        gap: 1rem;
      }
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
        transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
        opacity: 0;
        transform: translateY(8px);
      }
      .card.in { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s, box-shadow 0.25s, border-color 0.25s; }
      @media (prefers-reduced-motion: reduce) {
        .card { opacity: 1; transform: none; transition: none; }
      }
      .card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow);
        border-color: var(--border-strong);
      }
      .card-span-2 { grid-column: span 2; }
      .card-greeting { background: var(--ink); color: var(--bg); }
      .card-greeting .card-eyebrow { color: rgba(255, 255, 255, 0.5); }
      .card-greeting-text { font-size: 1.0625rem; line-height: 1.55; font-weight: 400; }
      .card-greeting-text strong { color: white; font-weight: 600; }
      .card-eyebrow {
        font-family: var(--mono);
        font-size: 0.6875rem;
        color: var(--ink-faint);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.65rem;
      }
      .card-big {
        font-family: var(--display);
        font-size: 1.625rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0.5rem;
      }
      .card-big-link {
        font-family: var(--mono);
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--primary);
        margin-bottom: 0.25rem;
      }
      .card-link:hover .card-big-link { color: var(--ink); }
      .card-small { color: var(--ink-mute); font-size: 0.8125rem; }
      .card-now { background: linear-gradient(135deg, var(--primary-soft), rgba(238, 242, 255, 0.4)); border-color: rgba(99, 102, 241, 0.25); }
      .card-loc { position: relative; }
      .map-dot {
        position: absolute; right: 1.25rem; bottom: 1.25rem;
        width: 14px; height: 14px;
        border-radius: 50%;
        background: var(--warm);
        box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2), 0 0 0 12px rgba(249, 115, 22, 0.08);
        animation: pulse 2.4s ease-in-out infinite;
      }
      .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
      .chips li {
        font-family: var(--mono);
        font-size: 0.7rem;
        padding: 0.25rem 0.55rem;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 5px;
        color: var(--ink-mute);
      }
      .big-num {
        font-family: var(--display);
        font-size: 3.25rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.5rem;
        background: var(--grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .big-num span { font-size: 0.55em; vertical-align: top; }
      .card-accent-warm .big-num { background: linear-gradient(135deg, #f97316, #ef4444); -webkit-background-clip: text; background-clip: text; color: transparent; }
      .card-link { display: block; }

      @media (max-width: 940px) {
        .bento { grid-template-columns: repeat(2, 1fr); }
        .card-span-2 { grid-column: span 2; }
      }
      @media (max-width: 540px) {
        .bento { grid-template-columns: 1fr; }
        .card-span-2 { grid-column: span 1; }
      }

      /* ===== WORK ===== */
      .work-bento { display: grid; gap: 1rem; }
      .work-feat {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0;
        display: grid;
        grid-template-columns: 1fr 1.05fr;
        overflow: hidden;
        position: relative;
        opacity: 0; transform: translateY(8px);
      }
      .work-feat.in { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s; }
      @media (prefers-reduced-motion: reduce) { .work-feat { opacity: 1; transform: none; } }
      .work-feat:hover { box-shadow: var(--shadow-lg); }
      .work-feat-body { padding: 2rem 2.25rem; }
      .work-badge {
        display: inline-block;
        font-family: var(--mono);
        font-size: 0.7rem;
        background: rgba(16, 185, 129, 0.1);
        color: #047857;
        padding: 0.25rem 0.6rem;
        border-radius: 999px;
        margin-bottom: 1rem;
      }
      .work-feat-title { font-size: 1.875rem; margin-bottom: 0.4rem; }
      .work-feat-meta { font-family: var(--mono); color: var(--ink-faint); font-size: 0.75rem; margin-bottom: 1rem; }
      .work-feat-desc { color: var(--ink-mute); margin-bottom: 1.25rem; }
      .work-feat-chips { list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1.5rem; }
      .work-feat-chips li {
        font-family: var(--mono);
        font-size: 0.7rem;
        padding: 0.25rem 0.55rem;
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 5px;
        color: var(--ink-mute);
      }
      .link-arrow {
        display: inline-flex; align-items: center; gap: 0.4rem;
        color: var(--primary);
        font-weight: 600;
        font-size: 0.9375rem;
        transition: gap 0.2s;
      }
      .link-arrow:hover { gap: 0.65rem; }
      .work-feat-visual {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
        position: relative;
        overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        padding: 2rem 1.5rem;
        min-height: 340px;
      }
      .visual-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        pointer-events: none;
      }
      .blob-1 { width: 220px; height: 220px; background: #ec4899; top: -40px; right: -40px; opacity: 0.3; }
      .blob-2 { width: 200px; height: 200px; background: #22d3ee; bottom: -50px; left: -40px; opacity: 0.3; }
      .visual-code {
        position: relative;
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 1rem 1.1rem;
        max-width: 100%;
        overflow-x: auto;
      }
      .visual-code pre { margin: 0; }
      .visual-code code {
        font-family: var(--mono);
        font-size: 0.7rem;
        color: #e4e4e7;
        background: none;
        padding: 0;
        line-height: 1.7;
        white-space: pre;
      }
      .code-c { color: #71717a; font-style: italic; }
      .code-k { color: #c084fc; }
      .code-t { color: #5eead4; }
      .code-s { color: #fbbf24; }
      .code-f { color: #93c5fd; }

      .work-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }
      .work-tile {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        display: flex; flex-direction: column;
        transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
        opacity: 0; transform: translateY(8px);
      }
      .work-tile.in { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s, box-shadow 0.25s, border-color 0.25s; }
      .work-tile:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--border-strong); }
      .work-tile img {
        width: 100%; aspect-ratio: 16 / 9; object-fit: cover; object-position: top;
        border-bottom: 1px solid var(--border);
      }
      .work-tile-body { padding: 1.1rem 1.25rem 1.25rem; flex: 1; display: flex; flex-direction: column; }
      .work-tile-body h4 { margin-bottom: 0.4rem; }
      .work-tile-body p { color: var(--ink-mute); font-size: 0.8125rem; margin-bottom: 0.75rem; flex: 1; }
      .tile-stack { color: var(--ink-faint); }
      .work-tile-text { padding-top: 1.5rem; }
      .work-tile-text .work-tile-body { padding-top: 0; }
      .work-tile-icon {
        font-size: 1.5rem;
        margin-bottom: 0.6rem;
        display: inline-block;
      }

      @media (max-width: 940px) {
        .work-feat { grid-template-columns: 1fr; }
        .work-feat-visual { min-height: 240px; }
        .work-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 540px) {
        .work-grid { grid-template-columns: 1fr; }
      }

      /* ===== writing ===== */
      .writing-empty {
        background: var(--bg-card);
        border: 1px dashed var(--border-strong);
        border-radius: var(--radius);
        padding: 2.5rem;
        max-width: 40rem;
      }
      .we-headline {
        font-family: var(--display);
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 0.85rem;
        letter-spacing: -0.02em;
      }
      .we-body { color: var(--ink-mute); margin-bottom: 1.25rem; }
      .we-cta { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; font-size: 0.9375rem; }
      .writing-list { list-style: none; }
      .writing-row {
        display: grid;
        grid-template-columns: 7rem 1fr auto;
        gap: 1.5rem;
        padding: 1.25rem 1.25rem;
        border-radius: var(--radius-sm);
        align-items: center;
        transition: background 0.2s, padding 0.2s;
        opacity: 0; transform: translateY(8px);
      }
      .writing-row.in { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s, background 0.2s, padding 0.2s; }
      .writing-row:hover { background: var(--bg-card); }
      .writing-row time { color: var(--ink-faint); padding-top: 0.2rem; }
      .writing-row h3 { font-size: 1.125rem; margin-bottom: 0.25rem; }
      .writing-row p { color: var(--ink-mute); font-size: 0.875rem; }
      .writing-arrow { color: var(--primary); font-size: 1.25rem; }

      /* ===== cta ===== */
      .cta-section { padding: 5rem 1.5rem; position: relative; z-index: 2; }
      .cta-card {
        background: var(--ink);
        color: var(--bg);
        border-radius: 24px;
        padding: 4rem 2rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        max-width: 56rem;
        margin: 0 auto;
        opacity: 0; transform: translateY(8px);
      }
      .cta-card.in { opacity: 1; transform: translateY(0); transition: opacity 0.5s, transform 0.5s; }
      .cta-card::before, .cta-card::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
      }
      .cta-card::before { width: 300px; height: 300px; background: #6366f1; top: -100px; left: -80px; opacity: 0.35; }
      .cta-card::after { width: 320px; height: 320px; background: #ec4899; bottom: -120px; right: -100px; opacity: 0.3; }
      .cta-card .card-eyebrow { color: rgba(255, 255, 255, 0.5); position: relative; z-index: 1; }
      .cta-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 900;
        letter-spacing: -0.035em;
        margin-bottom: 1rem;
        position: relative; z-index: 1;
      }
      .cta-text { color: rgba(255, 255, 255, 0.8); max-width: 32rem; margin: 0 auto 2rem; position: relative; z-index: 1; }
      .cta-text strong { color: white; }
      .cta-actions { display: flex; justify-content: center; gap: 0.65rem; flex-wrap: wrap; position: relative; z-index: 1; }
      .cta-actions .btn-primary { background: white; color: var(--ink); }
      .cta-actions .btn-ghost { background: transparent; color: white; border-color: rgba(255, 255, 255, 0.25); }
      .cta-actions .btn-ghost:hover { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.4); }

      /* ===== footer ===== */
      .foot { padding: 2rem 0; border-top: 1px solid var(--border); position: relative; z-index: 2; }
      .foot-inner {
        display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;
        color: var(--ink-faint);
      }
      .foot a { color: var(--primary); border-bottom: 1px dotted currentColor; }

      @media (max-width: 940px) {
        .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
        .hero { padding-top: 3rem; }
      }
    </style>
  </body>
</html>
