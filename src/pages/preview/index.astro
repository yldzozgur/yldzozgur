---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = [
  {
    name: 'Ameza Smart Retail Platform',
    type: 'Production · Volunteer',
    period: 'Nov 2025 — Present',
    stack: ['TypeScript', 'React', 'Node', 'PostgreSQL'],
    summary: 'Multi-tenant POS platform. 20+ merged PRs across the stack.',
    thumb: null,
    primary: 'https://github.com/Ameza-Smart-Retail-Solutions',
    code: null,
    primaryLabel: 'View org',
    badge: 'Currently shipping',
  },
  {
    name: 'Stock Management',
    type: 'Full-Stack · MERN',
    period: '2025',
    stack: ['React', 'Redux', 'Express', 'MongoDB'],
    summary: 'Inventory + sales dashboard with role-based auth, KPIs, and Swagger docs.',
    thumb: '/projects/stock-management.webp',
    primary: 'https://ozguryildiz-stock.vercel.app',
    code: 'https://github.com/yldzozgur/stock-management-app',
    primaryLabel: 'Open live',
    badge: null,
  },
  {
    name: 'Pizza API',
    type: 'Backend · REST',
    period: '2025',
    stack: ['Express', 'MongoDB', 'JWT', 'Swagger'],
    summary: 'Production-style REST API with auth, uploads, pagination, and Swagger UI.',
    thumb: '/projects/pizza-api.webp',
    primary: 'https://ozguryildiz-pizza-api.vercel.app',
    code: 'https://github.com/yldzozgur/pizza-api',
    primaryLabel: 'Open live',
    badge: null,
  },
  {
    name: 'Rent-A-Car API',
    type: 'Backend · REST',
    period: '2025',
    stack: ['Express', 'MongoDB', 'JWT', 'Nodemailer'],
    summary: 'Car rental REST with date-overlap detection, unique-field validation, email.',
    thumb: '/projects/rentacar-api.webp',
    primary: 'https://ozguryildiz-rentacar-api.vercel.app',
    code: 'https://github.com/yldzozgur/rent-a-car-api',
    primaryLabel: 'Open live',
    badge: null,
  },
  {
    name: 'Recipe App',
    type: 'Frontend · React 19',
    period: '2025',
    stack: ['React 19', 'Vite', 'Tailwind'],
    summary: 'Recipe discovery SPA with live search, category filters, and dark mode.',
    thumb: '/projects/recipe-app.webp',
    primary: 'https://yldzozgur.github.io/recipe-app/',
    code: 'https://github.com/yldzozgur/recipe-app',
    primaryLabel: 'Open live',
    badge: null,
  },
  {
    name: 'React Movie App',
    type: 'Frontend · Firebase',
    period: '2025',
    stack: ['React', 'Firebase', 'TMDB API'],
    summary: 'Movie discovery with Firebase auth (email + Google) and TMDB integration.',
    thumb: '/projects/react-movieapp.webp',
    primary: 'https://yldzozgur.github.io/react-movieapp/',
    code: 'https://github.com/yldzozgur/react-movieapp',
    primaryLabel: 'Open live',
    badge: null,
  },
];

const stats = [
  { num: '6+', label: 'years prior', note: 'Java · .NET enterprise' },
  { num: '20+', label: 'PRs merged', note: 'multi-tenant retail platform' },
  { num: '7', label: 'projects', note: 'live demos & APIs' },
  { num: '0', label: 'sponsorship', note: 'U.S. work authorized' },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>Ozgur Yildiz — Full-Stack Engineer (preview v2)</title>
    <meta name="description" content="Junior full-stack engineer based in Austin, TX. TypeScript · React · Node · PostgreSQL." />
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <header class="nav">
      <div class="nav-inner">
        <a href="/preview" class="brand">
          <span class="brand-mark">OY</span>
          <span class="brand-name">Ozgur Yildiz</span>
        </a>
        <nav class="nav-links">
          <a href="#work">Work</a>
          <a href="#writing">Writing</a>
          <a href="#about">About</a>
        </nav>
        <a href="/resume.pdf" class="nav-cta" target="_blank" rel="noopener">Resume</a>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-glow hero-glow-1"></div>
        <div class="hero-glow hero-glow-2"></div>
        <div class="hero-inner">
          <span class="status-pill">
            <span class="status-dot"></span>
            Available · open to remote (US) &amp; hybrid (Austin)
          </span>
          <p class="overline">Ozgur Yildiz · Austin, TX</p>
          <h1 class="hero-title">
            I build production<br />
            software in <span class="gradient-text">TypeScript</span>,<br />
            React &amp; Node.
          </h1>
          <p class="hero-sub">
            Currently shipping features at <strong>Ameza Solutions</strong> — a multi-tenant
            retail platform. Six years of prior Java &amp; .NET enterprise experience,
            re-tooled around the modern JS stack via an MBA and the Clarusway full-stack bootcamp.
          </p>
          <div class="hero-ctas">
            <a href="#work" class="btn btn-primary">
              See my work
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="#writing" class="btn btn-ghost">Read writing</a>
          </div>
          <ul class="hero-meta mono">
            <li>TypeScript</li>
            <li>·</li>
            <li>React</li>
            <li>·</li>
            <li>Node</li>
            <li>·</li>
            <li>Express</li>
            <li>·</li>
            <li>PostgreSQL</li>
            <li>·</li>
            <li>MongoDB</li>
          </ul>
        </div>
      </section>

      <section class="stats-section">
        <div class="container">
          <ul class="stats-grid">
            {stats.map((s) => (
              <li class="stat-card">
                <div class="stat-num">{s.num}</div>
                <div class="stat-label mono">{s.label}</div>
                <div class="stat-note">{s.note}</div>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section id="work" class="section">
        <div class="container">
          <header class="section-head">
            <div>
              <p class="section-eyebrow mono">/ work</p>
              <h2>Selected projects</h2>
            </div>
            <p class="section-lede">
              Live demos and open-source code from the past 18 months.
              Demo credentials: <code>demo@demo.com</code> / <code>Demo1234!</code>
            </p>
          </header>

          <ul class="work-grid">
            {projects.map((p) => (
              <li class="work-card">
                {p.thumb ? (
                  <a href={p.primary} target="_blank" rel="noopener" class="work-thumb">
                    <img src={p.thumb} alt={`${p.name} preview`} loading="lazy" decoding="async" width="1200" height="800" />
                    <span class="work-thumb-glow"></span>
                  </a>
                ) : (
                  <div class="work-thumb work-thumb-placeholder">
                    <svg viewBox="0 0 80 80" fill="none" stroke="currentColor" stroke-width="1.5">
                      <rect x="10" y="20" width="60" height="40" rx="4" />
                      <circle cx="40" cy="40" r="6" />
                      <path d="M20 50 L36 38 L48 46 L60 30" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <span class="mono">private repository</span>
                  </div>
                )}
                <div class="work-body">
                  <div class="work-head">
                    <h3 class="work-name">{p.name}</h3>
                    {p.badge && <span class="work-badge">{p.badge}</span>}
                  </div>
                  <p class="work-type mono">{p.type} · {p.period}</p>
                  <p class="work-summary">{p.summary}</p>
                  <ul class="work-stack">
                    {p.stack.map((s) => <li class="mono">{s}</li>)}
                  </ul>
                  <div class="work-links">
                    <a href={p.primary} target="_blank" rel="noopener" class="work-link mono">
                      {p.primaryLabel}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
                    </a>
                    {p.code && (
                      <a href={p.code} target="_blank" rel="noopener" class="work-link mono dim">
                        Code
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
                      </a>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section id="about" class="section section-alt">
        <div class="container">
          <div class="about-grid">
            <div>
              <p class="section-eyebrow mono">/ about</p>
              <h2>Engineer first.<br/>Writer second.</h2>
              <div class="about-prose">
                <p>
                  I'm a junior full-stack engineer with an unusual background. Before bootcamp
                  I spent six years writing enterprise software in Java and .NET — high-traffic
                  e-commerce at Ebebek, an asset management system at Lactalis, and Android &amp;
                  .NET tools at Gaga Software. Real teams, real code review, real production
                  incidents.
                </p>
                <p>
                  In 2023 I relocated to the U.S. and spent two years doing three things at
                  once: an MBA, intensive English, and the Clarusway full-stack bootcamp. Today
                  I'm shipping TypeScript and React features at Ameza Solutions and writing
                  twice a week about the gap between bootcamp code and real codebases.
                </p>
              </div>
            </div>
            <div class="about-side">
              <div class="info-card">
                <p class="info-label mono">Currently</p>
                <p>Full-Stack Developer @ <strong>Ameza Solutions</strong></p>
              </div>
              <div class="info-card">
                <p class="info-label mono">Authorized for</p>
                <p>U.S. work — no sponsorship now or in the future</p>
              </div>
              <div class="info-card">
                <p class="info-label mono">Looking for</p>
                <p>Junior full-stack or backend · remote (US) or hybrid (Austin)</p>
              </div>
              <div class="info-card info-card-cta">
                <p class="info-label mono">Get in touch</p>
                <a href="mailto:ozguryildiz0@outlook.com" class="info-link">
                  ozguryildiz0@outlook.com
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H8M17 7v9"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="writing" class="section">
        <div class="container">
          <header class="section-head">
            <div>
              <p class="section-eyebrow mono">/ writing</p>
              <h2>Posts twice a week</h2>
            </div>
            <p class="section-lede">
              Tuesday and Thursday. Notes on TypeScript, code review, and the unglamorous
              parts of shipping production software.
            </p>
          </header>

          {posts.length === 0 ? (
            <div class="writing-empty">
              <p class="writing-empty-headline">The queue is loaded.</p>
              <p class="writing-empty-note">
                First post lands shortly. Subscribe via
                <a href="/rss.xml">RSS</a>
                or follow on
                <a href="https://linkedin.com/in/ozguryildiz0" target="_blank" rel="noopener">LinkedIn ↗</a>
                to catch it.
              </p>
            </div>
          ) : (
            <ul class="writing-grid">
              {posts.map((post) => (
                <li class="writing-card">
                  <a href={`/writing/${post.id}`}>
                    <time class="mono dim" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="writing-arrow">Read →</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </section>

      <section class="cta-section">
        <div class="container cta-inner">
          <h2>Want to talk?</h2>
          <p>
            Open to remote (US-wide) and hybrid (Greater Austin) Junior Full-Stack
            or Backend roles. Reply same day.
          </p>
          <div class="cta-buttons">
            <a href="mailto:ozguryildiz0@outlook.com" class="btn btn-primary">Email me →</a>
            <a href="https://linkedin.com/in/ozguryildiz0" target="_blank" rel="noopener" class="btn btn-ghost">LinkedIn</a>
            <a href="https://github.com/yldzozgur" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="brand-mark small">OY</span>
          <span>Ozgur Yildiz · Austin, TX</span>
        </div>
        <p class="mono footer-note">
          Preview v2 · <a href="/">view current site</a>
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #0a0e16;
        --bg-elev: #131822;
        --bg-card: #161b27;
        --bg-card-hover: #1a2030;
        --border: #1f2937;
        --border-strong: #334155;
        --text: #f1f5f9;
        --text-muted: #94a3b8;
        --text-faint: #64748b;
        --c1: #22d3ee;
        --c2: #a78bfa;
        --c3: #f97316;
        --success: #10b981;
        --grad: linear-gradient(135deg, #22d3ee 0%, #a78bfa 100%);
        --grad-soft: linear-gradient(135deg, rgba(34, 211, 238, 0.12), rgba(167, 139, 250, 0.12));
        --font: 'Inter', system-ui, -apple-system, sans-serif;
        --mono: 'JetBrains Mono', monospace;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font);
        font-size: 16px;
        line-height: 1.55;
        font-weight: 400;
        overflow-x: hidden;
      }
      .container { max-width: 1180px; margin: 0 auto; padding: 0 1.5rem; }
      .mono { font-family: var(--mono); font-size: 0.75rem; letter-spacing: 0.02em; }
      .dim { color: var(--text-faint); }
      a { color: inherit; text-decoration: none; }

      h1, h2, h3 { font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
      h2 { font-size: clamp(2rem, 4vw, 3rem); }
      h3 { font-size: 1.1875rem; }
      code {
        font-family: var(--mono);
        font-size: 0.85em;
        background: rgba(255, 255, 255, 0.05);
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        color: var(--c1);
      }

      /* ---------- nav ---------- */
      .nav {
        position: sticky; top: 0; z-index: 50;
        background: rgba(10, 14, 22, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--border);
      }
      .nav-inner {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0.875rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        gap: 1.5rem;
      }
      .brand { display: flex; align-items: center; gap: 0.75rem; font-weight: 600; }
      .brand-mark {
        width: 2.25rem; height: 2.25rem;
        background: var(--grad);
        color: var(--bg);
        display: inline-flex; align-items: center; justify-content: center;
        font-family: var(--mono);
        font-size: 0.8125rem;
        font-weight: 700;
        border-radius: 8px;
      }
      .brand-mark.small { width: 1.75rem; height: 1.75rem; font-size: 0.6875rem; border-radius: 6px; }
      .brand-name { color: var(--text); }
      .nav-links { display: flex; gap: 2rem; font-size: 0.9375rem; }
      .nav-links a { color: var(--text-muted); transition: color 0.15s; }
      .nav-links a:hover { color: var(--text); }
      .nav-cta {
        padding: 0.5rem 1rem;
        border: 1px solid var(--border-strong);
        border-radius: 6px;
        color: var(--text);
        font-size: 0.875rem;
        font-weight: 500;
        transition: border-color 0.2s, transform 0.2s;
      }
      .nav-cta:hover { border-color: var(--c1); transform: translateY(-1px); }
      @media (max-width: 720px) {
        .nav-links { display: none; }
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        padding: 7rem 1.5rem 6rem;
        overflow: hidden;
      }
      .hero-glow {
        position: absolute;
        width: 600px; height: 600px;
        border-radius: 50%;
        filter: blur(120px);
        opacity: 0.15;
        pointer-events: none;
      }
      .hero-glow-1 { background: var(--c1); top: -200px; left: -200px; }
      .hero-glow-2 { background: var(--c2); top: -150px; right: -150px; }
      .hero-inner {
        max-width: 880px;
        margin: 0 auto;
        position: relative;
        text-align: left;
      }
      .status-pill {
        display: inline-flex; align-items: center; gap: 0.55rem;
        padding: 0.4rem 0.875rem;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: var(--success);
        border-radius: 999px;
        font-size: 0.8125rem;
        font-weight: 500;
        margin-bottom: 2rem;
      }
      .status-dot {
        width: 6px; height: 6px;
        background: var(--success);
        border-radius: 50%;
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.2);
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse { 50% { opacity: 0.5; } }
      .overline {
        font-family: var(--mono);
        font-size: 0.75rem;
        color: var(--text-faint);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }
      .hero-title {
        font-size: clamp(2.75rem, 6.5vw, 5rem);
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 1.02;
        margin-bottom: 1.75rem;
      }
      .gradient-text {
        background: var(--grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .hero-sub {
        font-size: 1.125rem;
        color: var(--text-muted);
        max-width: 38rem;
        margin-bottom: 2.5rem;
      }
      .hero-sub strong { color: var(--text); font-weight: 600; }
      .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2.25rem; }
      .btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 8px;
        font-size: 0.9375rem;
        font-weight: 500;
        transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      }
      .btn-primary {
        background: var(--grad);
        color: var(--bg);
        border: 1px solid transparent;
        box-shadow: 0 6px 20px -4px rgba(34, 211, 238, 0.25);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 28px -4px rgba(34, 211, 238, 0.4);
      }
      .btn-ghost {
        background: transparent;
        color: var(--text);
        border: 1px solid var(--border-strong);
      }
      .btn-ghost:hover { border-color: var(--c1); transform: translateY(-1px); }
      .hero-meta {
        list-style: none;
        display: flex;
        gap: 0.625rem;
        flex-wrap: wrap;
        color: var(--text-faint);
        font-size: 0.75rem;
      }

      /* ---------- stats ---------- */
      .stats-section { padding: 1.5rem 0 4rem; }
      .stats-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
      }
      .stat-card {
        padding: 1.5rem 1.25rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s;
      }
      .stat-card::before {
        content: ''; position: absolute; inset: 0 0 auto 0; height: 2px;
        background: var(--grad);
        opacity: 0.5;
      }
      .stat-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
      .stat-num {
        font-size: 2.25rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        background: var(--grad);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        line-height: 1;
        margin-bottom: 0.625rem;
      }
      .stat-label {
        color: var(--text);
        text-transform: uppercase;
        font-size: 0.6875rem;
        margin-bottom: 0.25rem;
      }
      .stat-note { color: var(--text-faint); font-size: 0.8125rem; }
      @media (max-width: 720px) {
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
      }

      /* ---------- sections ---------- */
      .section { padding: 5rem 0; }
      .section-alt {
        background: linear-gradient(180deg, transparent, var(--bg-elev) 30%, var(--bg-elev) 70%, transparent);
      }
      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 2rem;
        margin-bottom: 2.5rem;
        flex-wrap: wrap;
      }
      .section-eyebrow {
        color: var(--c1);
        text-transform: uppercase;
        font-size: 0.75rem;
        margin-bottom: 0.5rem;
      }
      .section-lede {
        color: var(--text-muted);
        font-size: 0.9375rem;
        max-width: 24rem;
      }

      /* ---------- work ---------- */
      .work-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }
      .work-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
        position: relative;
      }
      .work-card:hover {
        transform: translateY(-4px);
        border-color: var(--border-strong);
        box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.45);
      }
      .work-thumb {
        display: block;
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--bg-elev);
        border-bottom: 1px solid var(--border);
      }
      .work-thumb img {
        width: 100%; height: 100%; object-fit: cover; object-position: top;
        transition: transform 0.45s ease;
      }
      .work-card:hover .work-thumb img { transform: scale(1.03); }
      .work-thumb-glow {
        position: absolute; inset: 0;
        background: var(--grad-soft);
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
      }
      .work-card:hover .work-thumb-glow { opacity: 1; }
      .work-thumb-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        color: var(--text-faint);
      }
      .work-thumb-placeholder svg { width: 56px; height: 56px; opacity: 0.4; }
      .work-body { padding: 1.25rem 1.375rem 1.5rem; }
      .work-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem; margin-bottom: 0.4rem; }
      .work-name { font-size: 1.1875rem; }
      .work-badge {
        padding: 0.2rem 0.55rem;
        font-family: var(--mono);
        font-size: 0.6875rem;
        background: rgba(34, 211, 238, 0.1);
        color: var(--c1);
        border: 1px solid rgba(34, 211, 238, 0.25);
        border-radius: 999px;
        white-space: nowrap;
      }
      .work-type { color: var(--text-faint); margin-bottom: 0.75rem; text-transform: uppercase; font-size: 0.6875rem; }
      .work-summary { color: var(--text-muted); font-size: 0.9375rem; margin-bottom: 1rem; }
      .work-stack {
        list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem;
        margin-bottom: 1.25rem;
      }
      .work-stack li {
        padding: 0.2rem 0.55rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: 5px;
        color: var(--text-muted);
        font-size: 0.7rem;
      }
      .work-links { display: flex; gap: 1rem; align-items: center; }
      .work-link {
        display: inline-flex; align-items: center; gap: 0.3rem;
        color: var(--c1);
        font-size: 0.75rem;
        text-transform: uppercase;
        transition: gap 0.2s, color 0.15s;
      }
      .work-link:hover { gap: 0.5rem; }
      .work-link.dim { color: var(--text-muted); }
      .work-link.dim:hover { color: var(--text); }
      @media (max-width: 720px) {
        .work-grid { grid-template-columns: 1fr; }
      }

      /* ---------- about ---------- */
      .about-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 3rem;
        align-items: start;
      }
      .about-prose { margin-top: 1.5rem; color: var(--text-muted); }
      .about-prose p { margin-bottom: 1.125rem; font-size: 1rem; }
      .about-side { display: flex; flex-direction: column; gap: 0.75rem; }
      .info-card {
        padding: 1rem 1.125rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
      }
      .info-card p { color: var(--text); font-size: 0.9375rem; }
      .info-card strong { color: var(--c1); font-weight: 600; }
      .info-label {
        color: var(--text-faint);
        text-transform: uppercase;
        font-size: 0.6875rem;
        margin-bottom: 0.3rem;
      }
      .info-card-cta {
        background: var(--grad-soft);
        border-color: rgba(34, 211, 238, 0.3);
      }
      .info-link {
        display: inline-flex; align-items: center; gap: 0.4rem;
        color: var(--c1);
        font-weight: 600;
      }
      .info-link:hover { gap: 0.6rem; }
      @media (max-width: 720px) {
        .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      }

      /* ---------- writing ---------- */
      .writing-empty {
        padding: 2.5rem;
        background: var(--bg-card);
        border: 1px dashed var(--border-strong);
        border-radius: 12px;
        max-width: 36rem;
      }
      .writing-empty-headline {
        font-family: var(--mono);
        color: var(--c1);
        font-size: 0.875rem;
        margin-bottom: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }
      .writing-empty-note { color: var(--text-muted); font-size: 1rem; }
      .writing-empty-note a { color: var(--c1); border-bottom: 1px solid currentColor; margin: 0 0.2rem; }
      .writing-grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }
      .writing-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        transition: border-color 0.2s, transform 0.2s;
      }
      .writing-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
      .writing-card h3 { margin: 0.6rem 0 0.5rem; }
      .writing-card p { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1rem; }
      .writing-arrow { color: var(--c1); font-size: 0.8125rem; }
      @media (max-width: 720px) { .writing-grid { grid-template-columns: 1fr; } }

      /* ---------- cta ---------- */
      .cta-section { padding: 6rem 0; text-align: center; position: relative; }
      .cta-inner h2 { margin-bottom: 1rem; }
      .cta-inner p { color: var(--text-muted); max-width: 32rem; margin: 0 auto 2rem; }
      .cta-buttons { display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap; }

      /* ---------- footer ---------- */
      .footer { border-top: 1px solid var(--border); padding: 2rem 0; }
      .footer-inner {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
      }
      .footer-brand { display: flex; align-items: center; gap: 0.75rem; color: var(--text-muted); font-size: 0.875rem; }
      .footer-note { color: var(--text-faint); }
      .footer-note a { color: var(--c1); border-bottom: 1px dotted currentColor; }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
  </body>
</html>
