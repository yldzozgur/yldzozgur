---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout>
  <div class="spotlight" id="spotlight"></div>

  <!-- ============ HERO ============ -->
  <section class="hero">
    <div class="hero-grid container">
      <div class="hero-left">
        <span class="kicker">
          <span class="dot"></span>
          Curious · learning · building
        </span>
        <h1 class="display">
          Hi, I'm Ozgur.<br />
          <span class="accent-text">Full-Stack Developer.</span><br />
          Node.js · React · React Native.
        </h1>
        <p class="hero-lede">
          Full-Stack Developer based in Austin, TX. Currently building a React Native iOS app and Node.js backend at Guinn Partners. Previously 100+ merged PRs to a production TypeScript codebase at Ameza Solutions. Available for Full-Stack and Backend roles on US-based teams.
        </p>
        <div class="hero-cta">
          <a href="/work" class="btn btn-primary">
            See my work
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="/writing" class="btn btn-ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
            Writing
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="terminal">
          <div class="terminal-bar">
            <span class="t-dot dr"></span>
            <span class="t-dot dy"></span>
            <span class="t-dot dg"></span>
            <span class="t-name">ozgur@portfolio - zsh</span>
          </div>
          <pre class="t-body"><code><span class="t-c">~ </span><span class="t-prompt">$</span> uname -a
<span class="t-out">ozgur · software engineer · v∞</span>

<span class="t-c">~ </span><span class="t-prompt">$</span> stack --primary
<span class="t-out">typescript · react · node · express · postgres</span>

<span class="t-c">~ </span><span class="t-prompt">$</span> ps -e | head
<span class="t-out">read · break · fix · ship · repeat</span>

<span class="t-c">~ </span><span class="t-prompt">$</span> coffee --status
<span class="t-out"><span class="t-ok">●</span> always brewing</span>

<span class="t-c">~ </span><span class="t-prompt">$</span> <span class="t-cursor">█</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ABOUT BENTO ============ -->
  <section id="about" class="home-section">
    <div class="container">
      <div class="home-section-head">
        <h2 class="home-section-title">About.</h2>
        <p class="home-section-sub">A quick snapshot of who I am and what I work with.</p>
      </div>

      <div class="bento">
        <div class="bcard bcard-greeting bcard-span-2">
          <p class="bcard-eyebrow">/ intro</p>
          <p class="bcard-greeting-text">
            Full-Stack Developer building a <strong>React Native iOS app</strong> and Node.js backend at Guinn Partners. Previously 100+ merged PRs to a production TypeScript codebase at <strong>Ameza Solutions</strong>. Completed a full-stack bootcamp covering Node.js, Express, React, TypeScript, PostgreSQL, MongoDB, and Docker.
          </p>
        </div>

        <div class="bcard bcard-span-2">
          <p class="bcard-eyebrow">/ stack</p>
          <ul class="chips">
            <li>TypeScript</li><li>React</li><li>React Native</li><li>Node.js</li>
            <li>Express</li><li>PostgreSQL</li><li>MongoDB</li><li>Redux Toolkit</li>
            <li>Tailwind</li><li>Swagger</li><li>JWT</li><li>Docker</li>
            <li>Firebase Auth</li><li>Vercel</li><li>WebSocket</li><li>Cypress</li>
          </ul>
          <a href="/about" class="stack-link">Full stack on /about →</a>
        </div>

        <div class="bcard bcard-now">
          <p class="bcard-eyebrow">/ status</p>
          <p class="bcard-big">Open to work</p>
          <p class="bcard-small">Looking for a junior full-stack role.</p>
        </div>

        <div class="bcard">
          <p class="bcard-eyebrow">/ education</p>
          <p class="big-num">B.S.</p>
          <p class="bcard-small">Computer Engineering · M.B.A. · Clarusway Full-Stack Bootcamp 2024</p>
        </div>

        <div class="bcard">
          <p class="bcard-eyebrow">/ location</p>
          <p class="bcard-big">Austin, TX</p>
          <p class="bcard-small">Open to remote or on-site.</p>
        </div>

        <div class="bcard">
          <p class="bcard-eyebrow">/ learning</p>
          <p class="bcard-big">Testing &amp; performance</p>
          <p class="bcard-small">Writing tests I trust and debugging production issues.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ WORK ============ -->
  <section id="work" class="home-section home-section-alt">
    <div class="container">
      <div class="home-section-head">
        <h2 class="home-section-title">Selected work.</h2>
        <p class="home-section-sub">
          Live demos &amp; open-source code. Demo creds for all live demos:
          <code>demo@demo.com / Demo1234!</code>
        </p>
      </div>

      <div class="work-bento">
        <div class="work-grid">
          <a href="https://ozguryildiz-stock.vercel.app" target="_blank" rel="noopener" class="work-tile">
            <img src="/projects/stock-management.webp" alt="Stock Management" loading="lazy" />
            <div class="work-tile-body">
              <h4>Stock Management App</h4>
              <p>MERN · JWT auth · KPI dashboard · Swagger / Redoc.</p>
              <span class="tile-stack mono">React · Redux · MongoDB · JWT</span>
            </div>
          </a>

          <a href="https://ozguryildiz-pizza-api.vercel.app" target="_blank" rel="noopener" class="work-tile">
            <img src="/projects/pizza-api.webp" alt="Pizza API" loading="lazy" />
            <div class="work-tile-body">
              <h4>Pizza API</h4>
              <p>Production REST · JWT · uploads · CDN Swagger UI.</p>
              <span class="tile-stack mono">Express · MongoDB · Swagger</span>
            </div>
          </a>

          <a href="https://ozguryildiz-rentacar-api.vercel.app" target="_blank" rel="noopener" class="work-tile">
            <img src="/projects/rentacar-api.webp" alt="Rent-A-Car API" loading="lazy" />
            <div class="work-tile-body">
              <h4>Rent-A-Car API</h4>
              <p>Reservation logic with date-overlap detection &amp; email.</p>
              <span class="tile-stack mono">Express · MongoDB · Nodemailer</span>
            </div>
          </a>

          <a href="https://yldzozgur.github.io/react-movieapp/" target="_blank" rel="noopener" class="work-tile">
            <img src="/projects/react-movieapp.webp" alt="React Movie App" loading="lazy" />
            <div class="work-tile-body">
              <h4>React Movie App</h4>
              <p>Firebase auth (email + Google) · TMDB integration.</p>
              <span class="tile-stack mono">React · Firebase · TMDB</span>
            </div>
          </a>
        </div>
      </div>

      <div class="work-cta-row">
        <a href="/work" class="link-arrow">
          See all projects (4)
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ WRITING ============ -->
  <section id="writing" class="home-section">
    <div class="container">
      <div class="home-section-head">
        <h2 class="home-section-title">Writing.</h2>
        <p class="home-section-sub">
          Recent posts. <a href="/writing">Browse all →</a> · <a href="/rss.xml">RSS</a>
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="writing-empty">
          <p class="we-headline">📬 More posts coming soon.</p>
          <p class="we-body">
            More posts are on the way. Subscribe via RSS to catch the next one.
          </p>
          <div class="we-cta">
            <a href="/rss.xml" class="link-arrow">Subscribe via RSS</a>
            <span class="dim">·</span>
            <a href="https://linkedin.com/in/yldzozgur" target="_blank" rel="noopener" class="link-arrow">Follow on LinkedIn ↗</a>
          </div>
        </div>
      ) : (
        <ul class="writing-list">
          {posts.map((post) => (
            <li>
              <a href={`/writing/${post.id}`} class="writing-row">
                <time class="mono" datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                <div>
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                </div>
                <span class="writing-arrow">→</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-card">
        <p class="bcard-eyebrow">/ contact</p>
        <h2 class="cta-title">Get in touch.</h2>
        <p class="cta-text">
          Email is the fastest way to reach me. LinkedIn has my full career
          history, and GitHub has the code.
        </p>
        <div class="cta-actions">
          <a href="mailto:ozgur@yldzozgur.com" class="btn btn-primary">
            Email me
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="m22 6-10 7L2 6"/></svg>
          </a>
          <a href="https://linkedin.com/in/yldzozgur" target="_blank" rel="noopener" class="btn btn-cta-ghost">LinkedIn ↗</a>
          <a href="https://github.com/yldzozgur" target="_blank" rel="noopener" class="btn btn-cta-ghost">GitHub ↗</a>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const sp = document.getElementById('spotlight');
    if (sp && window.matchMedia('(min-width: 720px)').matches) {
      document.addEventListener('mousemove', (e) => {
        sp.style.setProperty('--mx', e.clientX + 'px');
        sp.style.setProperty('--my', e.clientY + 'px');
      });
    }
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('in'); });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.05 });
    document.querySelectorAll('.bcard, .work-tile, .work-feat, .writing-row, .cta-card').forEach(el => io.observe(el));
  </script>
</BaseLayout>

<style>
  /* spotlight */
  .spotlight {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: radial-gradient(560px circle at var(--mx, 50%) var(--my, 50%), rgba(99, 102, 241, 0.08), transparent 60%);
    opacity: 0.7;
  }

  /* hero */
  .hero { padding: 4rem 0 3rem; position: relative; z-index: 2; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: rgba(16, 185, 129, 0.1);
    color: #047857;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    margin-bottom: 2rem;
    border: 1px solid rgba(16, 185, 129, 0.2);
  }
  .kicker .dot {
    width: 6px;
    height: 6px;
    background: var(--success);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.2);
    animation: dot-pulse 2.4s ease-in-out infinite;
  }
  @keyframes dot-pulse { 50% { opacity: 0.45; } }

  .display {
    font-size: clamp(2.5rem, 6vw, 4.75rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin-bottom: 1.75rem;
  }
  .display .accent-text {
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    font-size: 1.0625rem;
    color: var(--ink-muted);
    max-width: 32rem;
    margin-bottom: 2rem;
    line-height: 1.65;
  }
  .hero-lede strong { color: var(--ink); font-weight: 600; }
  .link {
    color: var(--primary);
    font-weight: 500;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .link:hover { color: var(--ink); border-color: var(--ink); }
  .hero-cta { display: flex; gap: 0.65rem; flex-wrap: wrap; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    border-bottom: none;
  }
  .btn-primary {
    background: var(--ink);
    color: var(--bg);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
    border-bottom: none;
  }
  .btn-ghost {
    background: var(--bg-card);
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-strong);
    transform: translateY(-1px);
    border-bottom: 1px solid var(--border-strong);
  }

  /* terminal */
  .terminal {
    background: #18181b;
    color: #e4e4e7;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 24px 60px -20px rgba(24, 24, 27, 0.25), 0 0 0 1px rgba(24, 24, 27, 0.06);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
  }
  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 0.9rem;
    background: #27272a;
    border-bottom: 1px solid #3f3f46;
  }
  .t-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
  .dr { background: #ff5f57; }
  .dy { background: #febc2e; }
  .dg { background: #28c840; }
  .t-name { margin-left: 0.75rem; color: #a1a1aa; font-size: 0.7rem; }
  .t-body { padding: 1rem 1.25rem 1.25rem; margin: 0; overflow-x: auto; }
  .t-body code { background: none; color: inherit; padding: 0; font-size: inherit; border: none; }
  .t-prompt { color: #34d399; }
  .t-c { color: #a78bfa; }
  .t-out { color: #d4d4d8; }
  .t-ok { color: #34d399; }
  .t-cursor { color: #fbbf24; animation: blink 1s steps(2, start) infinite; }
  @keyframes blink { to { visibility: hidden; } }

  /* sections */
  .home-section { padding: 4.5rem 0; position: relative; z-index: 2; }
  .home-section-alt { background: var(--bg-soft); }
  .home-section-head { margin-bottom: 2.5rem; }
  .home-section-title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .home-section-sub {
    color: var(--ink-muted);
    font-size: 1rem;
    max-width: 38rem;
  }
  .home-section-sub code {
    font-size: 0.8125rem;
  }

  /* bento */
  .bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(170px, auto);
    gap: 1rem;
  }
  .bcard {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    opacity: 0;
    transform: translateY(8px);
    color: var(--ink);
    border-bottom: 1px solid var(--border);
  }
  .bcard.in {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  @media (prefers-reduced-motion: reduce) {
    .bcard { opacity: 1; transform: none; transition: none; }
  }
  .bcard:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--border-strong);
    border-bottom-color: var(--border-strong);
  }
  .bcard-span-2 { grid-column: span 2; }
  .bcard-greeting { background: var(--ink); color: var(--bg); }
  .bcard-greeting .bcard-eyebrow { color: rgba(255, 255, 255, 0.5); }
  .bcard-greeting-text {
    font-size: 1.0625rem;
    line-height: 1.55;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
  }
  .bcard-greeting-text strong { color: white; font-weight: 600; }
  .bcard-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.65rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .stack-link {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--primary);
    border-bottom: none;
  }
  .stack-link:hover {
    color: var(--ink);
    border-bottom: none;
  }
  .bcard-big {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }
  .bcard-small {
    color: var(--ink-muted);
    font-size: 0.8125rem;
  }
  .bcard-now {
    background: linear-gradient(135deg, var(--primary-soft), rgba(238, 242, 255, 0.4));
    border-color: rgba(99, 102, 241, 0.25);
  }
  .bcard-loc { position: relative; }
  .map-dot {
    position: absolute;
    right: 1.25rem;
    bottom: 1.25rem;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--warm);
    box-shadow: 0 0 0 4px rgba(249, 115, 22, 0.2), 0 0 0 12px rgba(249, 115, 22, 0.08);
    animation: dot-pulse 2.4s ease-in-out infinite;
  }
  .chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .chips li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.55rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--ink-muted);
  }
  .big-num {
    font-family: var(--font-display);
    font-size: 3.25rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.5rem;
    background: var(--grad);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .big-num span { font-size: 0.55em; vertical-align: top; }
  .bcard-warm .big-num {
    background: linear-gradient(135deg, #f97316, #ef4444);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* work */
  .work-bento { display: grid; gap: 1rem; }
  .work-feat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    overflow: hidden;
    position: relative;
    opacity: 0;
    transform: translateY(8px);
    border-bottom: 1px solid var(--border);
  }
  .work-feat.in {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  @media (prefers-reduced-motion: reduce) { .work-feat { opacity: 1; transform: none; } }
  .work-feat:hover { box-shadow: var(--shadow-lg); }
  .work-feat-body { padding: 2rem 2.25rem; }
  .work-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: rgba(16, 185, 129, 0.1);
    color: #047857;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .work-feat-title {
    font-size: 1.875rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }
  .work-feat-meta {
    font-family: var(--font-mono);
    color: var(--ink-faint);
    font-size: 0.75rem;
    margin-bottom: 1rem;
  }
  .work-feat-desc {
    color: var(--ink-muted);
    margin-bottom: 1.25rem;
    font-size: 0.9375rem;
  }
  .work-feat-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  .work-feat-chips li {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.25rem 0.55rem;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--ink-muted);
  }
  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9375rem;
    border-bottom: none;
    transition: gap 0.2s ease;
  }
  .link-arrow:hover {
    gap: 0.65rem;
    border-bottom: none;
  }
  .work-feat-visual {
    background: linear-gradient(135deg, #1e1b4b 0%, #312e81 100%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    min-height: 340px;
