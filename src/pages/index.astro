---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const featured = [
  {
    name: 'Ameza Smart Retail Platform',
    role: 'Volunteer Full-Stack Developer',
    period: '2025 — Present',
    stack: 'TypeScript · React · Node · PostgreSQL',
    note: '20+ merged PRs on a multi-tenant POS platform',
    href: 'https://github.com/Ameza-Smart-Retail-Solutions',
  },
  {
    name: 'Stock Management App',
    role: 'Solo build',
    period: '2025',
    stack: 'MERN · JWT · Redux Toolkit · Recharts',
    note: 'Full-stack inventory + sales dashboard with role-based auth',
    href: 'https://ozguryildiz-stock.vercel.app',
  },
  {
    name: 'Pizza API',
    role: 'Solo build',
    period: '2025',
    stack: 'Express · MongoDB · Swagger · Vercel',
    note: 'Production-style REST API with JWT and image upload',
    href: 'https://ozguryildiz-pizza-api.vercel.app',
  },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout>
  <section class="hero container">
    <div class="hero-meta mono">
      <span>Austin, TX</span>
      <span class="sep">/</span>
      <span>Full-Stack Engineer</span>
      <span class="sep">/</span>
      <span class="status"><span class="dot"></span> Available</span>
    </div>

    <h1 class="hero-title">
      Full-stack engineer.<br />
      <em>Six years</em> before TypeScript,<br />
      still learning every week.
    </h1>

    <p class="hero-lede">
      Currently shipping production features at <strong>Ameza Solutions</strong> — a multi-tenant retail
      platform in TypeScript, React, Node, and PostgreSQL. Before that: six years of Java
      and .NET enterprise work, then an MBA and a JS-stack bootcamp on the way to the U.S.
    </p>
    <p class="hero-lede hero-lede-secondary">
      I post twice a week here about the gap between bootcamp code and real codebases — what the
      courses don't tell you.
    </p>

    <div class="hero-actions">
      <a href="/work" class="cta">See the work →</a>
      <a href="/writing" class="cta-secondary">Read the writing</a>
    </div>
  </section>

  <section class="now-strip container" data-reveal-2>
    <div class="terminal">
      <div class="terminal-chrome">
        <span class="dot dot-r"></span>
        <span class="dot dot-y"></span>
        <span class="dot dot-g"></span>
        <span class="terminal-title mono">~/ozgur — status</span>
      </div>
      <pre class="terminal-body mono"><code><span class="t-prompt">$</span> ozgur --status
<span class="t-key">NOW SHIPPING</span>   Multi-tenant retail platform <span class="t-mute">@</span> Ameza Solutions
<span class="t-key">STACK</span>          TypeScript <span class="t-mute">·</span> React <span class="t-mute">·</span> Node <span class="t-mute">·</span> Express <span class="t-mute">·</span> PostgreSQL
<span class="t-key">WRITING</span>        Two posts <span class="t-mute">/</span> week <span class="t-mute">·</span> Tuesday <span class="t-mute">+</span> Thursday
<span class="t-key">AVAILABILITY</span>   Open to remote <span class="t-mute">(US)</span> <span class="t-mute">+</span> hybrid <span class="t-mute">(Austin)</span> <span class="t-mute">·</span> no sponsorship
<span class="t-prompt">$</span> <span class="t-cursor">_</span></code></pre>
    </div>
  </section>

  <section class="stats container" data-reveal-3>
    <dl class="stats-grid">
      <div class="stat">
        <dt class="stat-num">6+</dt>
        <dd class="mono stat-label">years prior</dd>
        <dd class="stat-note">Java · .NET enterprise</dd>
      </div>
      <div class="stat">
        <dt class="stat-num">20+</dt>
        <dd class="mono stat-label">PRs merged</dd>
        <dd class="stat-note">at Ameza, multi-tenant POS</dd>
      </div>
      <div class="stat">
        <dt class="stat-num">7</dt>
        <dd class="mono stat-label">projects</dd>
        <dd class="stat-note">live demos &amp; APIs shipped</dd>
      </div>
      <div class="stat">
        <dt class="stat-num">0</dt>
        <dd class="mono stat-label">sponsorship</dd>
        <dd class="stat-note">U.S. work authorized</dd>
      </div>
    </dl>
  </section>

  <section class="section container" data-reveal-3>
    <header class="section-header">
      <h2>Featured work</h2>
      <a href="/work" class="mono section-link">All projects →</a>
    </header>

    <ul class="work-list">
      {featured.map((p) => (
        <li class="work-row">
          <a href={p.href} target="_blank" rel="noopener" class="work-row-link">
            <div class="work-row-main">
              <span class="work-row-name">{p.name}</span>
              <span class="mono work-row-period">{p.period}</span>
            </div>
            <div class="work-row-meta">
              <span class="mono work-row-stack">{p.stack}</span>
            </div>
            <p class="work-row-note">{p.note}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {posts.length > 0 && (
    <section class="section container">
      <header class="section-header">
        <h2>Latest writing</h2>
        <a href="/writing" class="mono section-link">All posts →</a>
      </header>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-row">
            <a href={`/writing/${post.id}`} class="post-row-link">
              <time class="mono post-row-date" datetime={post.data.pubDate.toISOString()}>
                {formatDate(post.data.pubDate)}
              </time>
              <span class="post-row-title">{post.data.title}</span>
              <span class="post-row-arrow">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding-top: 5rem;
    padding-bottom: 4rem;
    max-width: 56rem;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--ink-muted);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .hero-meta .sep {
    color: var(--ink-faint);
  }
  .hero-meta .status {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--accent);
  }
  .hero-meta .dot {
    width: 6px;
    height: 6px;
    background: var(--accent);
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 0 4px var(--accent-glow);
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .hero-title {
    font-size: clamp(2.25rem, 5.5vw, 4rem);
    margin-bottom: 2rem;
  }
  .hero-title em {
    font-style: italic;
    color: var(--accent);
    font-variation-settings: "WONK" 1, "opsz" 144;
  }
  .hero-lede {
    font-size: 1.1875rem;
    line-height: 1.6;
    color: var(--ink-muted);
    max-width: 38rem;
    margin-bottom: 1.25rem;
  }
  .hero-lede strong {
    color: var(--ink);
    font-weight: 500;
  }
  .hero-lede-secondary {
    color: var(--ink-faint);
    font-size: 1.0625rem;
    margin-bottom: 2.5rem;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-block;
    background: var(--accent);
    color: var(--bg);
    padding: 0.75rem 1.25rem;
    border-radius: 4px;
    font-weight: 500;
    border-bottom: none;
    font-size: 0.9375rem;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .cta:hover {
    background: var(--link);
    border-bottom: none;
    transform: translateY(-1px);
  }
  .cta-secondary {
    display: inline-block;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    color: var(--ink);
    font-size: 0.9375rem;
    transition: border-color 0.2s ease;
  }
  .cta-secondary:hover {
    border-color: var(--accent);
    border-bottom: 1px solid var(--accent);
  }

  .now-strip {
    padding: 2.5rem 0 1.25rem;
  }
  .terminal {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #0a0c10;
    overflow: hidden;
    box-shadow: 0 0 0 1px rgba(232, 168, 56, 0.04), 0 16px 40px -16px rgba(0, 0, 0, 0.6);
    position: relative;
  }
  .terminal::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse at top, rgba(232, 168, 56, 0.04), transparent 60%);
  }
  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1rem;
    background: rgba(255, 255, 255, 0.025);
    border-bottom: 1px solid var(--border);
  }
  .terminal-chrome .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }
  .terminal-title {
    margin-left: 0.75rem;
    color: var(--ink-faint);
    font-size: 0.75rem;
  }
  .terminal-body {
    margin: 0;
    padding: 1.1rem 1.25rem;
    color: var(--ink-muted);
    font-size: 0.875rem;
    line-height: 1.7;
    overflow-x: auto;
    white-space: pre;
  }
  .terminal-body code {
    color: inherit;
    background: none;
    padding: 0;
    font-family: inherit;
  }
  .t-prompt { color: var(--accent); }
  .t-key { color: var(--accent-dim); }
  .t-mute { color: var(--ink-faint); }
  .t-cursor {
    display: inline-block;
    width: 0.55em;
    color: var(--accent);
    animation: blink 1.1s steps(2, start) infinite;
  }
  @keyframes blink {
    to { visibility: hidden; }
  }

  .stats {
    padding: 1.5rem 0 1rem;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .stat {
    padding: 1.25rem 1rem;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .stat:last-child {
    border-right: none;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 300;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.35rem;
  }
  .stat-label {
    color: var(--ink);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stat-note {
    color: var(--ink-faint);
    font-size: 0.75rem;
  }
  @media (max-width: 720px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat {
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .stat:nth-child(2n) { border-right: none; }
    .stat:nth-child(n+3) { border-bottom: none; }
  }
  @media (max-width: 640px) {
    .terminal-body {
      font-size: 0.8125rem;
      padding: 1rem;
    }
  }

  .section {
    padding: 3rem 0;
  }
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .section-link {
    color: var(--ink-muted);
    border-bottom: none;
  }
  .section-link:hover {
    color: var(--accent);
  }
  .empty {
    color: var(--ink-faint);
    padding: 2rem 0;
  }

  .post-list,
  .work-list {
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .post-row {
    border-bottom: 1px solid var(--border);
  }
  .post-row:last-child {
    border-bottom: none;
  }
  .post-row-link {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.25rem 0;
    color: var(--ink);
    border-bottom: none;
    transition: padding 0.2s ease;
  }
  .post-row-link:hover {
    border-bottom: none;
    padding-left: 0.5rem;
  }
  .post-row-link:hover .post-row-title {
    color: var(--accent);
  }
  .post-row-link:hover .post-row-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }
  .post-row-date {
    color: var(--ink-faint);
  }
  .post-row-title {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    transition: color 0.2s ease;
  }
  .post-row-arrow {
    color: var(--ink-faint);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .work-row {
    border-bottom: 1px solid var(--border);
  }
  .work-row:last-child {
    border-bottom: none;
  }
  .work-row-link {
    display: block;
    padding: 1.5rem 0;
    color: var(--ink);
    border-bottom: none;
    transition: padding 0.2s ease;
  }
  .work-row-link:hover {
    border-bottom: none;
    padding-left: 0.5rem;
  }
  .work-row-link:hover .work-row-name {
    color: var(--accent);
  }
  .work-row-main {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.4rem;
  }
  .work-row-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    transition: color 0.2s ease;
  }
  .work-row-period {
    color: var(--ink-faint);
  }
  .work-row-meta {
    margin-bottom: 0.5rem;
  }
  .work-row-stack {
    color: var(--accent-dim);
  }
  .work-row-note {
    color: var(--ink-muted);
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .post-row-link {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }
    .post-row-arrow {
      display: none;
    }
    .work-row-main {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
