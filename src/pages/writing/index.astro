---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Group by year
const postsByYear = posts.reduce<Record<string, typeof posts>>((acc, post) => {
  const year = post.data.pubDate.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Writing — Özgür Yıldız"
  description="Essays on TypeScript, Node.js, React, and what bootcamps don't teach you about real codebases."
>
  <section class="page-header container">
    <span class="mono dim">/ writing</span>
    <h1>Writing</h1>
    <p class="page-lede">
      Notes from the trenches of learning to ship production software.
      Mostly about TypeScript, Node, React, and the things that go wrong between
      the bootcamp tutorial and the real pull request.
    </p>
  </section>

  <section class="container">
    {posts.length === 0 ? (
      <div class="empty-state">
        <p class="mono dim">No posts yet — the first one is brewing.</p>
        <p class="empty-note">
          Check back soon, or subscribe via <a href="/rss.xml">RSS</a>.
        </p>
      </div>
    ) : (
      years.map((year) => (
        <div class="year-group">
          <h2 class="year-heading mono">{year}</h2>
          <ul class="post-list">
            {postsByYear[year].map((post) => (
              <li class="post-row">
                <a href={`/writing/${post.id}`} class="post-row-link">
                  <time class="mono post-row-date" datetime={post.data.pubDate.toISOString()}>
                    {formatDate(post.data.pubDate)}
                  </time>
                  <div class="post-row-body">
                    <h3 class="post-row-title">{post.data.title}</h3>
                    <p class="post-row-desc">{post.data.description}</p>
                    {post.data.tags.length > 0 && (
                      <div class="post-row-tags">
                        {post.data.tags.map((tag) => (
                          <span class="mono tag">#{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    )}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: 4rem;
    padding-bottom: 3rem;
    max-width: 48rem;
  }
  .page-header .dim {
    color: var(--ink-faint);
  }
  .page-header h1 {
    margin: 0.5rem 0 1.25rem;
  }
  .page-lede {
    font-family: var(--font-display);
    font-size: 1.3125rem;
    line-height: 1.5;
    color: var(--ink-muted);
    font-style: italic;
  }
  .empty-state {
    padding: 3rem 0;
    max-width: 36rem;
  }
  .empty-state .dim {
    color: var(--ink-faint);
    margin-bottom: 0.75rem;
  }
  .empty-note {
    color: var(--ink-muted);
  }

  .year-group {
    margin-bottom: 3rem;
  }
  .year-heading {
    font-size: 0.9375rem;
    color: var(--accent);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }
  .post-list {
    list-style: none;
  }
  .post-row {
    border-bottom: 1px solid var(--border);
  }
  .post-row:last-child {
    border-bottom: none;
  }
  .post-row-link {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 2rem;
    padding: 1.75rem 0;
    color: var(--ink);
    border-bottom: none;
    transition: padding 0.2s ease;
  }
  .post-row-link:hover {
    border-bottom: none;
    padding-left: 0.5rem;
  }
  .post-row-link:hover .post-row-title {
    color: var(--accent);
  }
  .post-row-date {
    color: var(--ink-faint);
    padding-top: 0.3rem;
  }
  .post-row-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1.25;
    margin-bottom: 0.5rem;
    transition: color 0.2s ease;
  }
  .post-row-desc {
    color: var(--ink-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.75rem;
  }
  .post-row-tags {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .tag {
    color: var(--accent-dim);
  }

  @media (max-width: 640px) {
    .post-row-link {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .post-row-date {
      padding-top: 0;
    }
  }
</style>
