---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tagSet = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tagSet.add(tag);
  }
  return [...tagSet].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title={`#${tag} — Writing — Ozgur Yildiz`}
  description={`Posts tagged #${tag} on the Ozgur Yildiz writing archive.`}
>
  <section class="page-header container">
    <span class="mono dim">/ writing / tags / <span class="tag-crumb">#{tag}</span></span>
    <h1>#{tag}</h1>
    <p class="page-lede">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'} tagged with this topic.
      <a href="/writing/tags" class="mono back-tags">← All tags</a>
    </p>
  </section>

  <section class="container">
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-row">
          <a href={`/writing/${post.id}`} class="post-row-link">
            <time class="mono post-row-date" datetime={post.data.pubDate.toISOString()}>
              {formatDate(post.data.pubDate)}
            </time>
            <div class="post-row-body">
              <h3 class="post-row-title">{post.data.title}</h3>
              <p class="post-row-desc">{post.data.description}</p>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .page-header { padding-top: 4rem; padding-bottom: 2.5rem; max-width: 48rem; }
  .page-header .dim { color: var(--ink-faint); }
  .tag-crumb { color: var(--accent); }
  .page-header h1 { margin: 0.5rem 0 1.25rem; color: var(--accent); font-family: var(--font-mono); font-size: 2rem; }
  .page-lede {
    font-family: var(--font-display);
    font-size: 1.1875rem;
    color: var(--ink-muted);
    font-style: italic;
  }
  .back-tags { margin-left: 1rem; color: var(--ink-faint); font-style: normal; font-size: 0.8125rem; }
  .post-list { list-style: none; }
  .post-row { border-bottom: 1px solid var(--border); }
  .post-row:last-child { border-bottom: none; }
  .post-row-link {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 2rem;
    padding: 1.5rem 0;
    color: var(--ink);
    border-bottom: none;
  }
  .post-row-link:hover .post-row-title { color: var(--accent); }
  .post-row-date { color: var(--ink-faint); padding-top: 0.3rem; }
  .post-row-title { font-family: var(--font-display); font-size: 1.25rem; margin-bottom: 0.4rem; transition: color 0.2s ease; }
  .post-row-desc { color: var(--ink-muted); font-size: 0.9375rem; }
  @media (max-width: 640px) {
    .post-row-link { grid-template-columns: 1fr; gap: 0.4rem; }
  }
</style>
